          v2Mode.className = 'tag ' + (v2Status === 'CANDIDATE' ? 'tag-open' : v2Status === 'WATCH' ? 'tag-dry' : 'tag-d');
        }
        const v2PnlEl = document.getElementById('shadowV2Pnl');
        if (v2PnlEl) {
          v2PnlEl.textContent = (v2Pnl >= 0 ? '+' : '-') + Math.abs(v2Pnl).toFixed(4) + ' SOL';
          v2PnlEl.style.color = v2Pnl > 0 ? 'var(--green)' : v2Pnl < 0 ? 'var(--red)' : 'var(--text)';
