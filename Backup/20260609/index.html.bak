        setText('shadowFalseNeg', String(s.false_negative_count || 0));
        setText('shadowCause', s.top_root_cause || 'none');
        const v1Status = document.getElementById('shadowV1Status');
        const v1Mode = document.getElementById('shadowV1Mode');
        const v1Pnl = document.getElementById('shadowV1Pnl');
        if (v1Status) {
          v1Status.textContent = status;
          v1Status.style.color =
            status === 'READY' ? 'var(--green)' :
            status === 'CANDIDATE' ? 'var(--yellow)' :
