          v1Pnl.style.color = pnl > 0 ? 'var(--green)' : pnl < 0 ? 'var(--red)' : 'var(--text)';
        }
        setText('shadowV1Impact', impact.toFixed(1) + '%');
        setText('shadowV1Cases', String(s.shadow_cases || 0));
        setText('shadowV1FalseNeg', String(s.false_negative_count || 0));
        setText('shadowV1Cause', s.top_root_cause || 'none');
