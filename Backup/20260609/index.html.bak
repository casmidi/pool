<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pool - quantum.or.id</title>
  <link rel="icon" type="image/svg+xml" href="https://quantum.or.id/images/quantum-icon.svg">
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="apple-touch-icon" href="/icons/pool-icon.svg">
  <meta name="theme-color" content="#0d0b14">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="Q Pool">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <script>
    (function () {
      var isMobile = /Android|iPhone|iPad|iPod|IEMobile|Opera Mini/i.test(navigator.userAgent || '') ||
        (window.matchMedia && window.matchMedia('(pointer: coarse)').matches) ||
        Math.min(window.innerWidth || 9999, screen.width || 9999) <= 900;
      if (isMobile) document.documentElement.classList.add('is-mobile');
    }());
  </script>
  <link
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <style>
    :root {
      --bg: #0d0b14;
      --surface: #13111e;
      --card: #19172a;
      --border: #2a2640;
      --border2: #3d3860;
      --accent: #9d8cff;
      --accent2: #c4b8ff;
      --green: #22d07a;
      --green-bg: rgba(34, 208, 122, 0.08);
      --green-b: rgba(34, 208, 122, 0.2);
      --red: #ff5a6e;
      --red-bg: rgba(255, 90, 110, 0.08);
      --red-b: rgba(255, 90, 110, 0.2);
      --yellow: #ffd166;
      --text: #e8e4ff;
      --muted: #7a7499;
      --muted2: #4a4670;
      --mono: 'IBM Plex Mono', monospace;
      --sans: 'IBM Plex Sans', sans-serif
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    html,
    body {
      height: 100%
    }

    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text);
      font-size: 14px
    }

    ::-webkit-scrollbar {
      width: 4px
    }

    ::-webkit-scrollbar-track {
      background: var(--bg)
    }

    ::-webkit-scrollbar-thumb {
      background: var(--border2);
      border-radius: 2px
    }

    .topbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 38px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 18px;
      gap: 10px;
      z-index: 100;
      font-family: var(--mono)
    }

    .topbar-icon {
      font-size: 15px;
      color: var(--accent)
    }

    .topbar-title {
      font-size: 12px;
      font-weight: 600;
      color: var(--accent2);
      letter-spacing: .08em;
      text-transform: uppercase
    }

    .topbar-badge {
      font-size: 10px;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 5px;
      background: #1e1c30;
      border: 1px solid var(--border2);
      color: var(--accent);
      letter-spacing: .04em
    }

    .topbar-badge.rev {
      color: var(--muted);
      font-weight: 400
    }

    .layout {
      display: flex;
      min-height: 100vh;
      padding-top: 38px
    }

    .sidebar {
      background: var(--surface);
      border-right: 1px solid var(--border);
      padding: 24px 0;
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 38px;
      width: 220px;
      height: calc(100vh - 38px);
      overflow-y: auto;
      z-index: 10
    }

    .logo {
      padding: 0 20px 24px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 16px
    }

    .logo-name {
      font-family: var(--mono);
      font-size: 16px;
      font-weight: 600;
      color: var(--accent2);
      letter-spacing: .04em
    }

    .logo-sub {
      font-size: 11px;
      color: var(--muted);
      margin-top: 2px;
      font-family: var(--mono)
    }

    .nav-section {
      padding: 0 12px;
      margin-bottom: 8px
    }

    .nav-label {
      font-size: 10px;
      font-weight: 600;
      color: var(--muted2);
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 0 8px;
      margin-bottom: 4px
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 10px;
      border-radius: 8px;
      cursor: pointer;
      color: var(--muted);
      font-size: 13px;
      transition: all .15s;
      text-decoration: none
    }

    .nav-item:hover {
      background: rgba(157, 140, 255, .08);
      color: var(--text)
    }

    .nav-item.active {
      background: rgba(157, 140, 255, .12);
      color: var(--accent2)
    }

    .nav-icon {
      width: 16px;
      height: 16px;
      opacity: .7
    }

    .sidebar-footer {
      margin-top: auto;
      padding: 16px 20px;
      border-top: 1px solid var(--border)
    }

    .bot-status {
      display: flex;
      align-items: center;
      gap: 8px
    }

    .status-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--green);
      flex-shrink: 0
    }

    .status-dot.live {
      animation: pulse 2s infinite
    }

    .status-dot.offline {
      background: var(--red)
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(34, 208, 122, .4)
      }

      50% {
        opacity: .7;
        box-shadow: 0 0 0 4px rgba(34, 208, 122, 0)
      }
    }

    .main {
      margin-left: 220px;
      padding: 28px;
      flex: 1;
      width: calc(100% - 220px)
    }

    .page {
      display: none;
      width: 100%
    }

    .page.active {
      display: block
    }

    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px
    }

    .page-title {
      font-size: 20px;
      font-weight: 500
    }

    .page-sub {
      font-size: 13px;
      color: var(--muted);
      margin-top: 2px
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 12px
    }

    .badge {
      font-family: var(--mono);
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 6px;
      font-weight: 500
    }

    .badge-dry {
      background: rgba(255, 209, 102, .12);
      color: var(--yellow);
      border: 1px solid rgba(255, 209, 102, .2)
    }

    .badge-live {
      background: var(--green-bg);
      color: var(--green);
      border: 1px solid var(--green-b)
    }

    .btn {
      background: var(--card);
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 7px 14px;
      border-radius: 8px;
      font-size: 12px;
      cursor: pointer;
      font-family: var(--sans);
      transition: all .15s;
      display: inline-flex;
      align-items: center;
      gap: 6px
    }

    .btn:hover {
      border-color: var(--accent);
      color: var(--accent)
    }

    .icon-btn {
      width: 34px;
      height: 34px;
      justify-content: center;
      padding: 0
    }

    .icon-btn svg {
      width: 15px;
      height: 15px
    }

    .scan-action-group {
      display: inline-flex;
      align-items: center;
      gap: 6px
    }

    .scan-panel {
      display: none;
      margin-bottom: 16px;
      border: 1px solid rgba(157, 140, 255, .22);
      background: #151324;
      border-radius: 8px;
      overflow: hidden
    }

    .scan-panel.open { display: block }

    .scan-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 14px;
      border-bottom: 1px solid var(--border)
    }

    .scan-title {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .12em;
      color: var(--accent2);
      text-transform: uppercase
    }

    .scan-summary {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 8px;
      padding: 12px 14px;
      border-bottom: 1px solid var(--border)
    }

    .scan-kpi {
      background: rgba(255,255,255,.025);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 8px
    }

    .scan-kpi span {
      display: block;
      font-size: 9px;
      color: var(--muted);
      font-family: var(--mono);
      text-transform: uppercase;
      letter-spacing: .08em;
      margin-bottom: 4px
    }

    .scan-kpi b {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--text)
    }

    .observer-panel {
      margin-bottom: 16px;
      border: 1px solid rgba(157, 140, 255, .22);
      background: #151324;
      border-radius: 8px;
      padding: 14px
    }

    .observer-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px
    }

    .observer-title {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .12em;
      color: var(--accent2);
      text-transform: uppercase
    }

    .observer-status {
      font-family: var(--mono);
      font-size: 11px;
      border-radius: 6px;
      padding: 5px 10px;
      border: 1px solid var(--border);
      color: var(--muted)
    }

    .observer-status.ready {
      color: var(--green);
      border-color: var(--green-b);
      background: var(--green-bg)
    }

    .observer-status.watch {
      color: var(--yellow);
      border-color: rgba(255, 209, 102, .25);
      background: rgba(255, 209, 102, .08)
    }

    .observer-status.hold {
      color: var(--muted);
      border-color: var(--border);
      background: rgba(255,255,255,.025)
    }

    .observer-status.danger {
      color: var(--red);
      border-color: var(--red-b);
      background: var(--red-bg)
    }

    .observer-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 8px;
      margin-bottom: 10px
    }

    .observer-kpi {
      background: rgba(255,255,255,.025);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 8px
    }

    .observer-kpi span {
      display: block;
      font-size: 9px;
      color: var(--muted);
      font-family: var(--mono);
      text-transform: uppercase;
      letter-spacing: .08em;
      margin-bottom: 4px
    }

    .observer-kpi b {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--text)
    }

    .observer-reason {
      font-size: 11px;
      color: var(--muted);
      font-family: var(--mono);
      margin-bottom: 10px
    }

    .observer-wallets {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px
    }

    .observer-scroll {
      max-height: 300px;
      overflow-y: auto;
      overflow-x: hidden;
      padding-right: 4px;
      display: flex;
      flex-direction: column
    }

    .observer-wallet {
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 8px;
      background: rgba(255,255,255,.02)
    }

    .observer-wallet-name {
      font-size: 12px;
      color: var(--text);
      font-family: var(--mono);
      font-weight: 700;
      margin-bottom: 4px
    }

    .observer-wallet-sub {
      font-size: 10px;
      color: var(--muted);
      font-family: var(--mono);
      line-height: 1.5
    }

    .meme-chart {
      margin-top: 8px;
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
      background: #0a0a12
    }

    .meme-chart summary {
      cursor: pointer;
      padding: 6px 8px;
      color: var(--accent);
      font-family: var(--mono);
      font-size: 10px
    }

    .meme-chart iframe {
      width: 100%;
      height: 220px;
      border: 0;
      display: block
    }

    .scan-losses {
      padding: 8px 0;
      max-height: 360px;
      overflow: auto;
      font-family: var(--mono);
      font-size: 11px
    }

    .scan-loss {
      padding: 10px 0;
      border-bottom: 1px solid rgba(42,38,64,.75)
    }

    .scan-loss:last-child { border-bottom: 0 }

    .scan-loss-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--text);
      margin-bottom: 6px
    }

    .scan-stage {
      color: var(--yellow);
      border: 1px solid rgba(255,209,102,.25);
      background: rgba(255,209,102,.08);
      border-radius: 5px;
      padding: 2px 6px;
      white-space: nowrap
    }

    .scan-verdict {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 6px
    }

    .scan-probs {
      display: flex;
      flex-wrap: wrap;
      gap: 6px
    }

    .scan-probs span {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--accent2);
      background: rgba(157,140,255,.08);
      border: 1px solid rgba(157,140,255,.16);
      border-radius: 5px;
      padding: 3px 6px
    }

    .scan-log-line {
      display: flex;
      gap: 8px;
      padding: 5px 12px;
      border-bottom: 1px solid rgba(42, 38, 64, .2);
      line-height: 1.5
    }

    .scan-log-line:hover { background: rgba(157, 140, 255, .03) }

    .scan-log-time {
      color: var(--muted2);
      flex-shrink: 0;
      width: 76px;
      font-size: 10px
    }

    .scan-log-tag {
      flex-shrink: 0;
      font-size: 10px;
      padding: 1px 6px;
      border-radius: 3px;
      height: fit-content;
      margin-top: 1px;
      width: 110px;
      text-align: center;
      background: rgba(157, 140, 255, .12);
      color: var(--accent2)
    }

    .scan-log-tag.loss,
    .scan-log-tag.false-negative {
      background: rgba(255, 90, 110, .15);
      color: var(--red)
    }

    .scan-log-tag.profit,
    .scan-log-tag.good-rejection {
      background: rgba(34, 208, 122, .1);
      color: var(--green)
    }

    .scan-log-tag.watch,
    .scan-log-tag.unclear {
      background: rgba(255, 209, 102, .12);
      color: var(--yellow)
    }

    .scan-log-msg {
      color: var(--text);
      white-space: pre-wrap;
      overflow-wrap: anywhere
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 24px
    }

    .stat-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px;
      transition: border-color .2s
    }

    .stat-card:hover {
      border-color: var(--border2)
    }

    .stat-label {
      font-size: 11px;
      color: var(--muted);
      font-family: var(--mono);
      letter-spacing: .06em;
      text-transform: uppercase;
      margin-bottom: 8px
    }

    .stat-value {
      font-family: var(--mono);
      font-size: 22px;
      font-weight: 600;
      color: var(--text);
      line-height: 1
    }

    .stat-value.green {
      color: var(--green)
    }

    .stat-value.red {
      color: var(--red)
    }

    .stat-change {
      font-size: 11px;
      margin-top: 6px;
      color: var(--muted)
    }

    .two-col {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 16px;
      margin-bottom: 16px;
      align-items: start
    }

    .cal-two {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
      align-items: start
    }

    .cal-two .card:first-child {
      min-height: calc(100vh - 180px)
    }

    .cycle-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 16px
    }

    .cycle-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 14px;
      display: flex;
      align-items: center;
      gap: 10px
    }

    .cycle-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      flex-shrink: 0
    }

    .cycle-label {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 2px
    }

    .cycle-time {
      font-family: var(--mono);
      font-size: 16px;
      font-weight: 600;
      color: var(--text)
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 16px;
      border-bottom: 1px solid var(--border)
    }

    .card-title {
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      font-family: var(--mono);
      letter-spacing: .08em;
      text-transform: uppercase
    }

    .card-body {
      padding: 16px
    }

    .pool-table {
      width: 100%;
      border-collapse: collapse
    }

    .pool-table th {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted2);
      text-transform: uppercase;
      letter-spacing: .08em;
      padding: 8px 12px;
      text-align: left;
      border-bottom: 1px solid var(--border)
    }

    .pool-table td {
      padding: 10px 12px;
      font-size: 12px;
      border-bottom: 1px solid rgba(42, 38, 64, .5);
      vertical-align: middle
    }

    .pool-table tr:last-child td {
      border-bottom: none
    }

    .pool-table tr:hover td {
      background: rgba(157, 140, 255, .04)
    }

    .watchlist-card {
      width: 100%
    }

    .watchlist-scroll {
      overflow-x: auto
    }

    .watchlist-table {
      min-width: 1380px;
      table-layout: fixed
    }

    .watchlist-table th:nth-child(1),
    .watchlist-table td:nth-child(1) {
      width: 330px
    }

    .watchlist-table th:nth-child(2),
    .watchlist-table td:nth-child(2) {
      width: 130px
    }

    .watchlist-table th:nth-child(3),
    .watchlist-table td:nth-child(3) {
      width: 125px
    }

    .watchlist-table th:nth-child(4),
    .watchlist-table td:nth-child(4),
    .watchlist-table th:nth-child(5),
    .watchlist-table td:nth-child(5),
    .watchlist-table th:nth-child(6),
    .watchlist-table td:nth-child(6) {
      width: 135px
    }

    .watchlist-table th:nth-child(7),
    .watchlist-table td:nth-child(7) {
      width: 100px
    }

    .watchlist-table th:nth-child(8),
    .watchlist-table td:nth-child(8) {
      width: 95px
    }

    .watchlist-table th:nth-child(9),
    .watchlist-table td:nth-child(9) {
      width: 110px
    }

    .watchlist-table .reason-line {
      max-width: 100%;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis
    }

    @media(min-width:1400px) {
      .main {
        padding-right: 18px
      }

      .watchlist-table {
        min-width: 0
      }
    }

    .pool-name {
      font-family: var(--mono);
      font-weight: 600;
      font-size: 13px;
      color: var(--text)
    }

    .pool-sub {
      color: var(--muted);
      font-size: 11px;
      margin-top: 2px
    }

    .obar {
      display: flex;
      align-items: center;
      gap: 6px
    }

    .bar-bg {
      flex: 1;
      height: 4px;
      background: var(--border);
      border-radius: 2px;
      overflow: hidden
    }

    .bar-fill {
      height: 100%;
      border-radius: 2px;
      transition: width .5s
    }

    .bar-fill.high {
      background: var(--green)
    }

    .bar-fill.low {
      background: var(--yellow)
    }

    .tag {
      font-size: 10px;
      font-family: var(--mono);
      padding: 2px 7px;
      border-radius: 4px
    }

    .tag-c {
      background: rgba(157, 140, 255, .12);
      color: var(--accent);
      border: 1px solid rgba(157, 140, 255, .2)
    }

    .tag-d {
      background: rgba(255, 90, 110, .08);
      color: var(--red);
      border: 1px solid var(--red-b)
    }

    .tag-open {
      background: rgba(34, 208, 122, .1);
      color: var(--green);
      border: 1px solid rgba(34, 208, 122, .22)
    }

    .tag-dry {
      background: rgba(255, 209, 102, .08);
      color: var(--yellow);
      border: 1px solid rgba(255, 209, 102, .22)
    }

    .impact-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      padding: 12px
    }

    .impact-summary {
      display: flex;
      gap: 16px;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      font-size: 11px;
      color: var(--muted);
      font-family: var(--mono)
    }

    .shadow-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 10px;
      padding: 12px
    }

    .shadow-kpi {
      border: 1px solid rgba(42, 38, 64, .75);
      border-radius: 8px;
      padding: 10px;
      background: rgba(255, 255, 255, .015);
      min-width: 0
    }

    .shadow-kpi span {
      display: block;
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 6px
    }

    .shadow-kpi b {
      display: block;
      font-family: var(--mono);
      font-size: 18px;
      color: var(--text);
      overflow-wrap: anywhere
    }

    .shadow-note {
      padding: 0 12px 12px;
      color: var(--muted);
      font-size: 11px;
      font-family: var(--mono)
    }

    .shadow-engine-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 16px
    }

    .shadow-version-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
      min-width: 0
    }

    .shadow-version-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
      margin-bottom: 14px
    }

    .shadow-version-title {
      font-family: var(--mono);
      font-size: 14px;
      font-weight: 700;
      letter-spacing: .04em;
      color: var(--text)
    }

    .shadow-version-sub {
      margin-top: 4px;
      font-size: 11px;
      color: var(--muted);
      font-family: var(--mono)
    }

    .shadow-mini-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px
    }

    .shadow-mini {
      border: 1px solid rgba(42, 38, 64, .75);
      border-radius: 8px;
      padding: 12px;
      background: rgba(255, 255, 255, .015);
      min-height: 72px;
      min-width: 0
    }

    .shadow-mini span {
      display: block;
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 8px
    }

    .shadow-mini b {
      display: block;
      font-family: var(--mono);
      font-size: 17px;
      line-height: 1.2;
      color: var(--text);
      overflow-wrap: anywhere
    }

    .impact-item {
      border: 1px solid rgba(42, 38, 64, .75);
      border-radius: 8px;
      padding: 10px;
      background: rgba(255, 255, 255, .015)
    }

    .impact-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      margin-bottom: 8px
    }

    .impact-title {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 700;
      color: var(--text)
    }

    .impact-status {
      font-family: var(--mono);
      font-size: 10px
    }

    .impact-meta {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 6px;
      font-size: 10px;
      color: var(--muted);
      margin-top: 8px
    }

    .impact-meta b {
      display: block;
      color: var(--text);
      font-family: var(--mono);
      font-size: 12px;
      margin-top: 2px
    }

    .bar-fill.watch {
      background: var(--yellow)
    }

    .bar-fill.bad {
      background: var(--red)
    }

    .organic-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-width: 92px;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text);
      white-space: nowrap
    }

    .organic-dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, .12);
      box-shadow: 0 0 0 1px rgba(0, 0, 0, .45);
      flex: 0 0 auto
    }

    .organic-dot.good {
      background: var(--green)
    }

    .organic-dot.watch {
      background: #ffe500
    }

    .organic-dot.bad {
      background: var(--red)
    }

    .metric-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--text);
      white-space: nowrap
    }

    .metric-badge .organic-dot {
      width: 12px;
      height: 12px
    }

    .metric-sub {
      margin-top: 4px;
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .05em;
      color: var(--muted2);
      text-transform: uppercase
    }

    .metric-sub.elite,
    .metric-sub.strong,
    .metric-sub.neutral,
    .metric-sub.accelerating,
    .metric-sub.stable {
      color: var(--green)
    }

    .metric-sub.weak,
    .metric-sub.danger,
    .metric-sub.decelerating,
    .metric-sub.avoid {
      color: var(--red)
    }

    .metric-sub.good {
      color: var(--accent2)
    }

    .reason-line {
      margin-top: 4px;
      max-width: 300px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-family: var(--mono);
      font-size: 9px;
      color: var(--muted);
      letter-spacing: .02em
    }

    .reason-line.blocked {
      color: var(--red)
    }

    .reason-line.watch {
      color: var(--yellow)
    }

    .reason-line.candidate {
      color: var(--green)
    }

    .reason-line.invalid {
      color: var(--red);
      font-weight: 700
    }

    .conf-breakdown summary {
      list-style: none;
      cursor: pointer
    }

    .conf-breakdown summary::-webkit-details-marker {
      display: none
    }

    .conf-lines {
      margin-top: 6px;
      display: grid;
      gap: 2px;
      min-width: 96px;
      font-family: var(--mono);
      font-size: 9px;
      color: var(--muted)
    }

    .conf-lines div {
      display: flex;
      justify-content: space-between;
      gap: 10px
    }

    .pool-organic-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin-left: 8px;
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      white-space: nowrap
    }

    .pool-organic-badge .organic-dot {
      width: 9px;
      height: 9px
    }

    .top-opps {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      padding: 12px
    }

    .top-opp {
      border: 1px solid rgba(42, 38, 64, .75);
      border-radius: 8px;
      padding: 10px;
      background: rgba(255, 255, 255, .015)
    }

    .top-opp-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 8px
    }

    .top-rank {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--accent);
      font-weight: 700
    }

    .top-edge {
      font-family: var(--mono);
      font-size: 15px;
      font-weight: 800;
      color: var(--text)
    }

    .timing-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--mono);
      font-size: 10px;
      padding: 2px 7px;
      border-radius: 4px;
      border: 1px solid rgba(157, 140, 255, .2);
      color: var(--accent)
    }

    .entry-sub {
      margin-top: 5px
    }

    .timing-badge.now {
      color: var(--green);
      border-color: var(--green-b);
      background: var(--green-bg)
    }

    .timing-badge.soon,
    .timing-badge.watch {
      color: var(--yellow);
      border-color: rgba(255, 209, 102, .22);
      background: rgba(255, 209, 102, .08)
    }

    .timing-badge.late {
      color: var(--red);
      border-color: var(--red-b);
      background: var(--red-bg)
    }

    .top-why {
      margin-top: 7px;
      display: grid;
      gap: 2px;
      font-family: var(--mono);
      font-size: 9px;
      color: var(--muted)
    }

    .top-why .good {
      color: var(--green)
    }

    .top-why .warn {
      color: var(--yellow)
    }

    .regime-strip {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 10px 12px;
      border-top: 1px solid var(--border);
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted)
    }

    .regime-state {
      font-size: 11px;
      font-weight: 800;
      color: var(--accent2)
    }

    .exec-panel {
      padding: 12px;
      display: grid;
      gap: 10px
    }

    .exec-summary {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px
    }

    .exec-kpi {
      border: 1px solid rgba(42, 38, 64, .75);
      border-radius: 8px;
      padding: 8px;
      background: rgba(255, 255, 255, .015)
    }

    .exec-kpi span {
      display: block;
      font-family: var(--mono);
      font-size: 9px;
      color: var(--muted2);
      letter-spacing: .06em;
      text-transform: uppercase
    }

    .exec-kpi b {
      display: block;
      margin-top: 4px;
      font-family: var(--mono);
      font-size: 13px;
      color: var(--text)
    }

    .allocation-list {
      display: grid;
      gap: 5px
    }

    .allocation-row {
      display: grid;
      grid-template-columns: 1fr auto auto;
      gap: 8px;
      align-items: center;
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted)
    }

    .table-scroll {
      overflow-x: auto
    }

    .deploy-scroll {
      max-height: 620px;
      overflow-y: auto;
      overflow-x: auto
    }

    .deploy-scroll .pool-table thead th {
      position: sticky;
      top: 0;
      z-index: 2;
      background: var(--card)
    }

    .ranking-scroll {
      max-height: 620px;
      overflow-y: auto;
      overflow-x: auto
    }

    .ranking-scroll .pool-table thead th {
      position: sticky;
      top: 0;
      z-index: 2;
      background: var(--card)
    }

    .candidate-scroll {
      max-height: 620px;
      overflow-y: auto;
      overflow-x: auto
    }

    .candidate-scroll .pool-table thead th {
      position: sticky;
      top: 0;
      z-index: 2;
      background: var(--card)
    }

    .mono {
      font-family: var(--mono)
    }

    .num-pos {
      color: var(--green);
      font-weight: 700
    }

    .num-neg {
      color: var(--red);
      font-weight: 700
    }

    .num-flat {
      color: var(--muted);
      font-weight: 600
    }

    .sec-sep {
      padding: 8px 12px;
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted2);
      letter-spacing: .08em;
      text-transform: uppercase;
      background: rgba(255, 255, 255, .02);
      border-bottom: 1px solid var(--border)
    }

    .log-wrap {
      font-family: var(--mono);
      font-size: 11px;
      max-height: 500px;
      overflow-y: auto;
      display: flex;
      flex-direction: column
    }

    .log-line {
      display: flex;
      gap: 8px;
      padding: 5px 12px;
      border-bottom: 1px solid rgba(42, 38, 64, .2);
      line-height: 1.5
    }

    .log-line:hover {
      background: rgba(157, 140, 255, .03)
    }

    .log-time {
      color: var(--muted2);
      flex-shrink: 0;
      width: 76px;
      font-size: 10px
    }

    .log-tag {
      flex-shrink: 0;
      font-size: 10px;
      padding: 1px 6px;
      border-radius: 3px;
      height: fit-content;
      margin-top: 1px;
      width: 92px;
      text-align: center
    }

    .lt-STARTUP {
      background: rgba(157, 140, 255, .15);
      color: var(--accent)
    }

    .lt-CRON {
      background: rgba(34, 208, 122, .1);
      color: var(--green)
    }

    .lt-ERROR,
    .lt-CRON_ERROR {
      background: rgba(255, 90, 110, .15);
      color: var(--red)
    }

    .lt-HIVEMIND_WARN {
      background: rgba(255, 209, 102, .1);
      color: var(--yellow)
    }

    .lt-SCREENING {
      background: rgba(196, 184, 255, .1);
      color: var(--accent2)
    }

    .lt-AGENT {
      background: rgba(157, 140, 255, .08);
      color: var(--accent)
    }

    .lt-INIT {
      background: rgba(34, 208, 122, .08);
      color: var(--green)
    }

    .lt-SHUTDOWN {
      background: rgba(255, 90, 110, .08);
      color: var(--red)
    }

    .lt-other {
      background: rgba(255, 255, 255, .04);
      color: var(--muted)
    }

    .log-msg {
      color: var(--text);
      flex: 1;
      word-break: break-word
    }

    .log-msg.err {
      color: var(--red)
    }

    .log-msg.warn {
      color: var(--yellow)
    }

    .wallet-addr {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent2);
      word-break: break-all;
      line-height: 1.6
    }

    .mrow {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 0;
      border-bottom: 1px solid var(--border)
    }

    .mrow:last-child {
      border-bottom: none
    }

    .mkey {
      font-size: 12px;
      color: var(--muted)
    }

    .mval {
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 600
    }

    .mval.g {
      color: var(--green)
    }

    .mval.r {
      color: var(--red)
    }

    .mval.w {
      color: var(--text)
    }

    .cal-hdr {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px
    }

    .cal-month-title {
      font-family: var(--mono);
      font-size: 14px;
      font-weight: 600;
      color: var(--text)
    }

    .cal-btn {
      background: none;
      border: 1px solid var(--border);
      color: var(--muted);
      width: 28px;
      height: 28px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: all .15s
    }

    .cal-btn:hover {
      border-color: var(--accent);
      color: var(--accent)
    }

    .cal-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 8px;
      min-height: calc(100vh - 270px)
    }

    .cdl {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted2);
      text-align: center;
      padding: 6px 0
    }

    .cd {
      border-radius: 6px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 10px 6px;
      min-height: 96px;
      cursor: default;
      transition: all .15s
    }

    .cd.profit {
      background: rgba(34, 208, 122, .12)
    }

    .cd.loss {
      background: rgba(255, 90, 110, .12)
    }

    .cd.zero {
      background: rgba(255, 255, 255, .03)
    }

    .cd.today {
      border: 1px solid var(--accent)
    }

    .cdn {
      font-size: 13px;
      color: #ffffff;
      font-weight: 600;
      line-height: 1;
      margin-bottom: 7px
    }

    .cdp {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      line-height: 1
    }

    .cdc {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 600;
      line-height: 1;
      margin-top: 6px;
      color: #ffffff
    }

    .cdc-loss {
      color: var(--red)
    }

    .cd.profit .cdp {
      color: var(--green)
    }

    .cd.loss .cdp {
      color: var(--red)
    }

    .cd.zero .cdp {
      color: #ffffff
    }

    .err-box {
      background: var(--red-bg);
      border: 1px solid var(--red-b);
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 12px;
      color: var(--red);
      margin-bottom: 12px;
      display: none
    }

    .budget-alert {
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      background: rgba(255, 209, 102, .08);
      border: 1px solid rgba(255, 209, 102, .24);
      border-radius: 10px;
      padding: 12px 14px;
      margin-bottom: 16px;
      color: var(--yellow);
      display: none
    }

    .budget-alert.danger {
      background: var(--red-bg);
      border-color: var(--red-b);
      color: var(--red)
    }

    .budget-alert strong {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: .06em;
      text-transform: uppercase;
      white-space: nowrap
    }

    .budget-alert span {
      color: var(--text);
      font-size: 12px;
      line-height: 1.4;
      text-align: right
    }

    @media(max-width:900px), (pointer:coarse) {
      .sidebar {
        position: fixed;
        top: auto;
        left: 0;
        right: 0;
        bottom: 0;
        width: 100%;
        height: 72px;
        padding: 7px 8px calc(7px + env(safe-area-inset-bottom));
        border-right: 0;
        border-top: 1px solid var(--border);
        overflow-x: auto;
        overflow-y: hidden;
        z-index: 50
      }

      .logo,
      .nav-label,
      .sidebar-footer {
        display: none
      }

      .nav-section {
        display: flex;
        gap: 6px;
        padding: 0;
        margin: 0;
        min-width: max-content
      }

      .nav-item {
        min-width: 74px;
        height: 56px;
        flex-direction: column;
        justify-content: center;
        gap: 4px;
        padding: 6px 8px;
        font-size: 10px;
        line-height: 1.15;
        text-align: center;
        white-space: normal
      }

      .nav-icon {
        width: 18px;
        height: 18px
      }

      .main {
        margin-left: 0;
        width: 100%;
        padding: 16px 12px 96px
      }

      .layout {
        padding-top: 38px
      }

      .topbar-title {
        max-width: 34vw;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap
      }

      .topbar-badge.rev {
        display: none
      }

      .page-header {
        align-items: flex-start;
        flex-direction: column;
        gap: 12px
      }

      .header-right {
        display: flex;
        gap: 8px;
        overflow-x: auto;
        width: 100%;
        padding-bottom: 2px
      }

      .header-right .btn {
        flex: 0 0 auto
      }

      .stats-grid {
        grid-template-columns: repeat(2, 1fr)
      }

      .observer-grid,
      .observer-wallets {
        grid-template-columns: 1fr 1fr
      }

      .two-col,
      .cal-two {
        grid-template-columns: 1fr
      }

      .cycle-row {
        grid-template-columns: 1fr 1fr
      }

      .budget-alert {
        align-items: flex-start;
        flex-direction: column
      }

      .budget-alert span {
        text-align: left
      }
    }

    @media(max-width:480px), (max-device-width:480px) {
      .stats-grid {
        grid-template-columns: 1fr
      }

      .observer-grid,
      .observer-wallets {
        grid-template-columns: 1fr
      }

      .stat-card {
        padding: 14px
      }

      .stat-value {
        font-size: 20px
      }

      .two-col,
      .cal-two,
      .cycle-row {
        grid-template-columns: 1fr
      }

      .shadow-engine-grid {
        grid-template-columns: 1fr
      }

      .topbar {
        padding: 0 12px;
        gap: 8px
      }

      .topbar-badge {
        display: none
      }
    }

    html.is-mobile .sidebar {
      position: fixed;
      top: auto;
      left: 0;
      right: 0;
      bottom: 0;
      width: 100%;
      height: 72px;
      padding: 7px 8px calc(7px + env(safe-area-inset-bottom));
      border-right: 0;
      border-top: 1px solid var(--border);
      overflow-x: auto;
      overflow-y: hidden;
      z-index: 50
    }

    html.is-mobile .logo,
    html.is-mobile .nav-label,
    html.is-mobile .sidebar-footer {
      display: none
    }

    html.is-mobile .nav-section {
      display: flex;
      gap: 6px;
      padding: 0;
      margin: 0;
      min-width: max-content
    }

    html.is-mobile .nav-item {
      min-width: 74px;
      height: 56px;
      flex-direction: column;
      justify-content: center;
      gap: 4px;
      padding: 6px 8px;
      font-size: 10px;
      line-height: 1.15;
      text-align: center;
      white-space: normal
    }

    html.is-mobile .nav-icon {
      width: 18px;
      height: 18px
    }

    html.is-mobile .main {
      margin-left: 0;
      width: 100%;
      padding: 16px 12px 96px
    }

    html.is-mobile .page-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px
    }

    html.is-mobile .stats-grid {
      grid-template-columns: repeat(2, 1fr)
    }

    html.is-mobile .shadow-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr))
    }

    html.is-mobile .header-right {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      width: 100%;
      padding-bottom: 2px
    }

    html.is-mobile .header-right .btn {
      flex: 0 0 auto
    }

    html.is-mobile .topbar-title {
      max-width: 34vw;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap
    }

    html.is-mobile .topbar-badge.rev {
      display: none
    }

    html.is-mobile .cal-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 6px;
      min-height: auto
    }

    html.is-mobile .cal-grid .cdl:nth-child(n+6) {
      display: none
    }

    html.is-mobile .cal-grid .cd {
      min-height: 80px;
      padding: 8px 4px
    }

    html.is-mobile .cal-grid .cdn {
      font-size: 12px
    }

    html.is-mobile .cal-grid .cdp {
      font-size: 10px
    }

    html.is-mobile .cal-grid .cdc {
      font-size: 9px
    }

    html.is-mobile .cal-two .card:first-child {
      min-height: auto
    }

    @media(max-width:480px), (max-device-width:480px) {
      html.is-mobile .stats-grid {
        grid-template-columns: 1fr
      }

      html.is-mobile .shadow-grid {
        grid-template-columns: 1fr
      }

      html.is-mobile .shadow-mini-grid {
        grid-template-columns: 1fr
      }
    }
  </style>
</head>

<body>
  <header class="topbar">
    <span class="topbar-icon">Q</span>
    <span class="topbar-title">Quantum Pool System</span>
    <span class="topbar-badge">v2.5</span>
    <span class="topbar-badge rev" id="revBadge">Rev. loading</span>
  </header>
  <div class="layout">
    <aside class="sidebar">
      <div class="logo">
        <div class="logo-name">Q Pool</div>
        <div class="logo-sub">quantum.or.id</div>
      </div>
      <div class="nav-section">
        <div class="nav-label">Dashboard</div>
        <a class="nav-item active" onclick="go('overview',this)">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <rect x="3" y="3" width="7" height="7" rx="1" stroke-width="1.5" />
            <rect x="14" y="3" width="7" height="7" rx="1" stroke-width="1.5" />
            <rect x="3" y="14" width="7" height="7" rx="1" stroke-width="1.5" />
            <rect x="14" y="14" width="7" height="7" rx="1" stroke-width="1.5" />
          </svg>
          Overview
        </a>
        <a class="nav-item" onclick="go('calendar',this)">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2" stroke-width="1.5" />
            <path d="M16 2v4M8 2v4M3 10h18" stroke-width="1.5" />
          </svg>
          PnL Calendar
        </a>
        <a class="nav-item" onclick="go('history',this)">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M3 5h18M3 12h18M3 19h18" stroke-width="1.5" />
            <path d="M7 5v14" stroke-width="1.5" />
          </svg>
          Trade History
        </a>
        <a class="nav-item" onclick="go('ranking',this)">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M4 19V5M4 19h16" stroke-width="1.5" />
            <path d="M8 15l3-3 3 2 5-7" stroke-width="1.5" />
          </svg>
          Ranking
        </a>
        <a class="nav-item" onclick="go('pools',this)">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="9" stroke-width="1.5" />
            <path d="M12 3v18M3 12h18" stroke-width="1.5" />
          </svg>
          Pool Candidates
        </a>
        <a class="nav-item" onclick="go('alpha',this)">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M5 12h14M13 6l6 6-6 6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M5 6h5M5 18h5" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          Alpha Lab
        </a>
        <a class="nav-item" onclick="go('shadow',this)">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M4 7c2.5-2 5.1-3 8-3s5.5 1 8 3c-2.5 2-5.1 3-8 3S6.5 9 4 7z" stroke-width="1.5" />
            <path d="M4 13c2.5 2 5.1 3 8 3s5.5-1 8-3M8 20h8" stroke-width="1.5" />
          </svg>
          Shadow Engine
        </a>
        <a class="nav-item" onclick="go('logs',this)">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke-width="1.5" />
            <path d="M14 2v6h6M16 13H8M16 17H8" stroke-width="1.5" />
          </svg>
          Log Activity
        </a>
      </div>
      <div class="sidebar-footer">
        <div class="bot-status">
          <div class="status-dot" id="sDot"></div>
          <div>
            <div style="font-size:12px;color:var(--text)" id="sTxt">Connecting...</div>
            <div style="font-size:10px;color:var(--muted);font-family:var(--mono)" id="sMode">--</div>
          </div>
        </div>
      </div>
    </aside>

    <main class="main">

      <!-- OVERVIEW -->
      <div id="page-overview" class="page active">
        <div class="page-header">
          <div>
            <div class="page-title">Overview</div>
            <div class="page-sub" id="agentId">Meridian DLMM Bot</div>
          </div>
          <div class="header-right">
            <span class="badge badge-dry" id="modeBadge">DRY RUN</span>
            <span class="scan-action-group">
              <button class="btn" onclick="toggleScanLog()">Scan Log</button>
              <button class="btn icon-btn" onclick="downloadForensicScan()" title="Download scan log hari ini" aria-label="Download scan log hari ini">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14" />
                </svg>
              </button>
            </span>
            <button class="btn" onclick="generateIncidentReport()">Incident</button>
            <button class="btn" onclick="loadAll()">Refresh</button>
          </div>
        </div>
        <div id="errBox" class="err-box"></div>
        <div id="scanPanel" class="scan-panel">
          <div class="scan-toolbar">
            <div>
              <div class="scan-title">Daily Forensic Scan</div>
              <div style="font-size:11px;color:var(--muted);font-family:var(--mono)" id="scanSource">--</div>
            </div>
            <button class="btn" onclick="loadForensicScan()">Refresh Scan</button>
          </div>
          <div class="scan-summary" id="scanSummary"></div>
          <div class="scan-losses" id="scanLosses">
            <div style="color:var(--muted);font-size:12px;padding:8px">Click Scan Log to load today's forensic scan.</div>
          </div>
        </div>
        <div id="aiBudgetAlert" class="budget-alert"></div>
        <div id="operatorAlert" class="budget-alert"></div>
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-label">SOL Balance</div>
            <div class="stat-value" id="solBal">--</div>
            <div class="stat-change" id="solUsd">$0.00</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Monthly PnL</div>
            <div class="stat-value green" id="monthPnl">0.0000 SOL</div>
            <div class="stat-change" id="tDays">0 trading days</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Daily PnL</div>
            <div class="stat-value" id="dailyPnl">0.0000 SOL</div>
            <div class="stat-change" id="dailyPnlSub">today | $0.00</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Active Pools</div>
            <div class="stat-value" id="actPools">0</div>
            <div class="stat-change" id="poolSub">no positions</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Win Rate</div>
            <div class="stat-value" id="winRate">--</div>
            <div class="stat-change" id="scrCnt">0 trades | 0 screenings</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Darwin Boost</div>
            <div class="stat-value" id="darwinBoost">0%</div>
            <div class="stat-change" id="darwinSub">no recalcs yet</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Bot Health</div>
            <div class="stat-value" id="botHealth">--</div>
            <div class="stat-change" id="botHealthSub">waiting for trades</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">AI Mode</div>
            <div class="stat-value" id="aiMode">--</div>
            <div class="stat-change" id="aiModeSub">waiting for budget</div>
          </div>
        </div>
        <!-- SIMULATION CAPITAL BADGE -->
        <div id="simCapBadge" style="display:none;margin-bottom:16px;background:linear-gradient(135deg,rgba(157,140,255,.08),rgba(34,208,122,.04));border:1px solid rgba(157,140,255,.2);border-radius:12px;padding:16px 20px">
          <div style="font-size:10px;font-weight:700;letter-spacing:2px;color:var(--accent);margin-bottom:4px">SIMULATION CAPITAL</div>
          <div style="font-size:11px;color:var(--muted);font-family:var(--mono);margin-bottom:12px">since dry-run started</div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px">
            <div>
              <div style="font-size:10px;color:var(--muted);margin-bottom:4px">INITIAL</div>
              <div style="font-size:20px;font-weight:700;color:var(--text);font-family:var(--mono)" id="scInitial">0.00 SOL</div>
              <div style="font-size:11px;color:var(--muted);margin-top:2px" id="scInitialUsd">$0.00</div>
            </div>
            <div>
              <div style="font-size:10px;color:var(--muted);margin-bottom:4px">CURRENT</div>
              <div style="font-size:20px;font-weight:700;color:var(--text);font-family:var(--mono)" id="scCurrent">0.0000 SOL</div>
              <div style="font-size:11px;color:var(--muted);margin-top:2px" id="scCurrentUsd">$0.00</div>
            </div>
            <div>
              <div style="font-size:10px;color:var(--muted);margin-bottom:4px">NET P&amp;L</div>
              <div style="font-size:20px;font-weight:700;font-family:var(--mono)" id="scPnl">+0.0000 SOL</div>
              <div style="font-size:11px;margin-top:2px" id="scPct">$0.00 | 0.00%</div>
            </div>
          </div>
        </div>
        <div class="cycle-row">
          <div class="cycle-card">
            <div class="cycle-icon" style="background:rgba(157,140,255,.1)">M</div>
            <div>
              <div class="cycle-label">Management</div>
              <div class="cycle-time" id="mTimer">--</div>
            </div>
          </div>
          <div class="cycle-card">
            <div class="cycle-icon" style="background:rgba(34,208,122,.1)">S</div>
            <div>
              <div class="cycle-label">Screening</div>
              <div class="cycle-time" id="sTimer">--</div>
            </div>
          </div>
          <div class="cycle-card">
            <div class="cycle-icon" style="background:rgba(255,209,102,.1)">U</div>
            <div>
              <div class="cycle-label">Uptime</div>
              <div class="cycle-time" id="uptime">--</div>
            </div>
          </div>
        </div>
        <div class="card" style="margin-bottom:16px">
          <div class="card-header"><span class="card-title">Feature Impact</span><span
              style="font-size:11px;color:var(--muted)" id="featureImpactUpdated">--</span></div>
          <div class="impact-summary">
            <span id="featureTopHelper">Top Helper: --</span>
            <span id="featureMostAggressive">Most Aggressive: --</span>
          </div>
          <div class="impact-grid" id="featureImpactGrid">
            <div style="color:var(--muted);font-size:12px;padding:8px">Loading...</div>
          </div>
        </div>
        <div class="two-col">
          <div style="display:flex;flex-direction:column;gap:12px">
          <div class="card">
            <div class="card-header"><span class="card-title">Top Opportunities</span><span
                style="font-size:11px;color:var(--muted)" id="regimeCnt">--</span></div>
            <div class="top-opps" id="topOpps">
              <div style="color:var(--muted);font-size:12px;padding:8px">Loading...</div>
            </div>
            <div class="regime-strip" id="marketRegime">
              <span class="regime-state">--</span><span>candidate --</span><span>blocked --</span>
            </div>
          </div>
          <div class="card">
            <div class="card-header"><span class="card-title">Execution Intelligence</span><span
                style="font-size:11px;color:var(--muted)" id="riskBudgetState">--</span></div>
            <div class="exec-panel">
              <div class="exec-summary" id="execSummary">
                <div class="exec-kpi"><span>Risk</span><b>--</b></div>
                <div class="exec-kpi"><span>Exposure</span><b>--</b></div>
                <div class="exec-kpi"><span>Executable</span><b>--</b></div>
                <div class="exec-kpi"><span>Blocked</span><b>--</b></div>
              </div>
              <div class="allocation-list" id="capitalAllocation">
                <div style="color:var(--muted);font-size:12px;padding:4px">Loading...</div>
              </div>
            </div>
          </div>
          <div class="card">
            <div class="card-header"><span class="card-title">Fast Market Mode</span><span
                style="font-size:11px;color:var(--muted)" id="fastMarketState">--</span></div>
            <div class="exec-panel">
              <div class="exec-summary" id="momentumRiderSummary">
                <div class="exec-kpi"><span>Mode</span><b>--</b></div>
                <div class="exec-kpi"><span>Trades</span><b>--</b></div>
                <div class="exec-kpi"><span>PF</span><b>--</b></div>
                <div class="exec-kpi"><span>OOR</span><b>--</b></div>
              </div>
              <div class="allocation-list" id="momentumRiderDetail">
                <div style="color:var(--muted);font-size:12px;padding:4px">Loading...</div>
              </div>
            </div>
          </div>
          <div class="card watchlist-card">
            <div class="card-header"><span class="card-title">Opportunity Watchlist</span><span
                style="font-size:11px;color:var(--muted)" id="poolCnt">--</span></div>
            <div class="watchlist-scroll" style="padding:0">
              <table class="pool-table watchlist-table">
                <thead>
                  <tr>
                    <th>Pool</th>
                    <th>Edge</th>
                    <th>Size</th>
                    <th>Wallet</th>
                    <th>Organic</th>
                    <th>FeeTVL</th>
                    <th>Alpha</th>
                    <th>Conf</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody id="poolBody">
                  <tr>
                    <td colspan="9" style="text-align:center;color:var(--muted);padding:24px;font-size:12px">Loading...
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:12px">
            <div class="card">
              <div class="card-header"><span class="card-title">Wallet</span></div>
              <div class="card-body">
                <div
                  style="font-size:10px;color:var(--muted2);font-family:var(--mono);letter-spacing:.06em;margin-bottom:6px">
                  SOLANA ADDRESS</div>
                <div class="wallet-addr" id="wAddr">Loading...</div>
                <div style="margin-top:10px;display:flex;gap:12px">
                  <a id="scanLink" href="#" target="_blank"
                    style="font-size:11px;color:var(--accent);text-decoration:none;font-family:var(--mono)">Solscan
                    -></a>
                  <a href="https://app.meteora.ag" target="_blank"
                    style="font-size:11px;color:var(--muted);text-decoration:none;font-family:var(--mono)">Meteora -></a>
                </div>
              </div>
            </div>
            <div class="card">
              <div class="card-header"><span class="card-title">This Month</span></div>
              <div class="card-body">
                <div class="mrow"><span class="mkey">Total PnL</span><span class="mval g" id="mTotal">0.0000 SOL</span></div>
                <div class="mrow"><span class="mkey">Best Day</span><span class="mval g" id="mBest">0.0000 SOL</span></div>
                <div class="mrow"><span class="mkey">Worst Day</span><span class="mval r" id="mWorst">0.0000 SOL</span></div>
                <div class="mrow"><span class="mkey">Trading Days</span><span class="mval w" id="mDays">0</span></div>
                <div class="mrow"><span class="mkey">Screenings</span><span class="mval w" id="mScr">0</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CALENDAR -->
      <div id="page-calendar" class="page">
        <div class="page-header">
          <div>
            <div class="page-title">PnL Calendar</div>
            <div class="page-sub">Daily profit & loss</div>
          </div>
        </div>
        <div class="cal-two">
          <div class="card">
            <div class="card-body">
              <div class="cal-hdr">
                <button class="cal-btn" onclick="prevM()">&lt;</button>
                <span class="cal-month-title" id="calT">May 2026</span>
                <button class="cal-btn" onclick="nextM()">&gt;</button>
              </div>
              <div class="cal-grid" id="calG"></div>
            </div>
          </div>
          <div class="card">
            <div class="card-header"><span class="card-title">Monthly Summary</span></div>
            <div class="card-body">
              <div class="mrow"><span class="mkey">Total PnL</span><span class="mval g" id="csT">0.0000 SOL</span></div>
              <div class="mrow"><span class="mkey">Best Day</span><span class="mval g" id="csB">0.0000 SOL</span></div>
              <div class="mrow"><span class="mkey">Worst Day</span><span class="mval r" id="csW">0.0000 SOL</span></div>
              <div class="mrow"><span class="mkey">Trading Days</span><span class="mval w" id="csD">0</span></div>
              <div
                style="margin-top:16px;padding:12px;background:rgba(157,140,255,.05);border-radius:8px;border:1px solid rgba(157,140,255,.1)">
                <div style="font-size:11px;color:var(--muted);margin-bottom:4px">Note</div>
                <div style="font-size:12px;color:var(--muted)">Calendar akan terisi setelah ada live trading. Sekarang
                  masih DRY RUN.</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- RANKING -->
      <div id="page-ranking" class="page">
        <div class="page-header">
          <div>
            <div class="page-title">Wallet Ranking</div>
            <div class="page-sub">Advanced intelligent LP ranking engine</div>
          </div>
          <button class="btn" onclick="loadRanking()">Refresh</button>
        </div>
        <div class="card">
          <div class="card-header"><span class="card-title">Top Wallets</span><span
              style="font-size:11px;color:var(--muted)" id="rankCnt">--</span></div>
          <div class="table-scroll ranking-scroll">
            <table class="pool-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Wallet</th>
                  <th>Score</th>
                  <th>Grade</th>
                  <th>7D PnL</th>
                  <th>30D PnL</th>
                  <th>Fees</th>
                  <th>Win Rate</th>
                </tr>
              </thead>
              <tbody id="rankBody">
                <tr>
                  <td colspan="8" style="text-align:center;color:var(--muted);padding:32px;font-size:12px">Loading...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- HISTORY -->
      <div id="page-history" class="page">
        <div class="page-header">
          <div>
            <div class="page-title">Trade History</div>
            <div class="page-sub">Pools that have been deployed</div>
          </div>
          <button class="btn" onclick="loadPnl()">Refresh</button>
        </div>
        <div class="card">
          <div class="card-header"><span class="card-title">Pool Deployments</span><span
              style="font-size:11px;color:var(--muted)" id="tradeCnt">--</span></div>
          <div class="table-scroll deploy-scroll">
            <table class="pool-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Pool</th>
                  <th>Status</th>
                  <th>Amount</th>
                  <th>Strategy</th>
                  <th>PnL</th>
                  <th>Exit Pool</th>
                  <th>Reason</th>
                  <th>Duration</th>
                  <th>Time</th>
                </tr>
              </thead>
              <tbody id="tradeBody">
                <tr>
                  <td colspan="10" style="text-align:center;color:var(--muted);padding:32px;font-size:12px">Loading...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- POOLS -->
      <div id="page-pools" class="page">
        <div class="page-header">
          <div>
            <div class="page-title">Pool Candidates</div>
            <div class="page-sub">Screened every 30 minutes</div>
          </div>
          <button class="btn" onclick="loadPools()">Refresh</button>
        </div>
        <div class="card">
          <div class="candidate-scroll" style="padding:0">
            <table class="pool-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Pool</th>
                  <th>Score</th>
                  <th>Confidence</th>
                  <th>Grade</th>
                  <th>Organic</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody id="poolFull">
                <tr>
                  <td colspan="7" style="text-align:center;color:var(--muted);padding:32px;font-size:12px">Loading...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- ALPHA LAB -->
      <div id="page-alpha" class="page">
        <div class="page-header">
          <div>
            <div class="page-title">Alpha Lab</div>
            <div class="page-sub">Observer signals only, not connected to engine</div>
          </div>
          <button class="btn" onclick="loadSmartWalletObserver()">Refresh</button>
        </div>
        <div class="observer-panel" id="smartWalletObserver">
          <div class="observer-head">
            <div>
              <div class="observer-title">Smart Wallet Observer</div>
              <div class="observer-reason" id="swoReason" style="margin:4px 0 0">learning only | engine impact none</div>
            </div>
            <span class="scan-action-group">
              <span class="observer-status hold" id="swoStatus">HOLD</span>
              <button class="btn icon-btn" onclick="downloadSmartWalletObserver()" title="Download smart wallet observer log" aria-label="Download smart wallet observer log">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14" />
                </svg>
              </button>
            </span>
          </div>
          <div class="observer-grid">
            <div class="observer-kpi"><span>Confidence</span><b id="swoConf">0%</b></div>
            <div class="observer-kpi"><span>Samples</span><b id="swoSamples">0</b></div>
            <div class="observer-kpi"><span>Wallets</span><b id="swoWallets">0</b></div>
            <div class="observer-kpi"><span>Promising</span><b id="swoPromising">0</b></div>
            <div class="observer-kpi"><span>Engine</span><b id="swoEngine">OFF</b></div>
          </div>
          <div class="observer-wallets observer-scroll" id="swoWalletList">
            <div class="observer-wallet">
              <div class="observer-wallet-name">Waiting</div>
              <div class="observer-wallet-sub">observer snapshot not loaded yet</div>
            </div>
          </div>
        </div>
        <div class="observer-panel">
          <div class="observer-head">
            <div>
              <div class="observer-title">Meme Alpha Finder</div>
              <div class="observer-reason" id="mafReason" style="margin:4px 0 0">report only | buy/sell manual</div>
            </div>
            <span class="scan-action-group">
              <span class="observer-status hold" id="mafStatus">HOLD</span>
              <button class="btn icon-btn" onclick="downloadMemeAlphaFinder()" title="Download meme alpha finder log" aria-label="Download meme alpha finder log">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14" />
                </svg>
              </button>
            </span>
          </div>
          <div class="observer-grid">
            <div class="observer-kpi"><span>Scanned</span><b id="mafScanned">0</b></div>
            <div class="observer-kpi"><span>Hot</span><b id="mafHot">0</b></div>
            <div class="observer-kpi"><span>Watch</span><b id="mafWatch">0</b></div>
            <div class="observer-kpi"><span>Danger</span><b id="mafDanger">0</b></div>
            <div class="observer-kpi"><span>Engine</span><b id="mafEngine">OFF</b></div>
          </div>
          <div class="observer-wallets observer-scroll" id="mafList">
            <div class="observer-wallet">
              <div class="observer-wallet-name">Loading</div>
              <div class="observer-wallet-sub">waiting for meme alpha snapshot</div>
            </div>
          </div>
        </div>
      </div>

      <!-- SHADOW ENGINE -->
      <div id="page-shadow" class="page">
        <div class="page-header">
          <div>
            <div class="page-title">Shadow Engine</div>
            <div class="page-sub">Replay evidence and pre-trade truth layers</div>
          </div>
          <button class="btn" onclick="loadShadowIntelligence(); loadAiUsage()">Refresh</button>
        </div>
        <div class="shadow-engine-grid">
          <div class="shadow-version-card">
            <div class="shadow-version-head">
              <div>
                <div class="shadow-version-title">Shadow v1</div>
                <div class="shadow-version-sub">rejection replay</div>
              </div>
              <span class="tag tag-dry" id="shadowV1Mode">LEARNING</span>
            </div>
            <div class="shadow-mini-grid">
              <div class="shadow-mini"><span>Status</span><b id="shadowV1Status">--</b></div>
              <div class="shadow-mini"><span>Shadow PnL</span><b id="shadowV1Pnl">--</b></div>
              <div class="shadow-mini"><span>Impact</span><b id="shadowV1Impact">--</b></div>
              <div class="shadow-mini"><span>Cases</span><b id="shadowV1Cases">--</b></div>
              <div class="shadow-mini"><span>False Neg</span><b id="shadowV1FalseNeg">--</b></div>
              <div class="shadow-mini"><span>Top Cause</span><b id="shadowV1Cause">--</b></div>
            </div>
            <div class="shadow-note" style="padding:12px 0 0">No auto-deploy | no production learning | rejection replay only</div>
          </div>
          <div class="shadow-version-card">
            <div class="shadow-version-head">
              <div>
                <div class="shadow-version-title">Shadow v2</div>
                <div class="shadow-version-sub">pre-trade truth</div>
              </div>
              <span class="tag tag-d" id="shadowV2Mode">STANDBY</span>
            </div>
            <div class="shadow-mini-grid">
              <div class="shadow-mini"><span>Status</span><b id="shadowV2Status">STANDBY</b></div>
              <div class="shadow-mini"><span>Truth PnL</span><b id="shadowV2Pnl">+0.0000 SOL</b></div>
              <div class="shadow-mini"><span>Exit Route</span><b id="shadowV2ExitRoute">--</b></div>
              <div class="shadow-mini"><span>Cases</span><b id="shadowV2Cases">0</b></div>
              <div class="shadow-mini"><span>Cluster Risk</span><b id="shadowV2ClusterRisk">--</b></div>
              <div class="shadow-mini"><span>Top Cause</span><b id="shadowV2Cause">none</b></div>
              <div class="shadow-mini"><span>Adaptive PnL</span><b id="shadowV2AdaptivePnl">+0.0000 SOL</b></div>
              <div class="shadow-mini"><span>Best Route</span><b id="shadowV2AdaptiveRoute">none</b></div>
            </div>
            <div class="shadow-note" style="padding:12px 0 0">No auto-deploy | no hard gate | truth preflight pending</div>
          </div>
          <div class="shadow-version-card">
            <div class="shadow-version-head">
              <div>
                <div class="shadow-version-title">Shadow v3</div>
                <div class="shadow-version-sub">wallet rescue</div>
              </div>
              <span class="tag tag-d" id="shadowV3Mode">LEARNING</span>
            </div>
            <div class="shadow-mini-grid">
              <div class="shadow-mini"><span>Status</span><b id="shadowV3Status">LEARNING</b></div>
              <div class="shadow-mini"><span>Rescue PnL</span><b id="shadowV3Pnl">+0.0000 SOL</b></div>
              <div class="shadow-mini"><span>Cases</span><b id="shadowV3Cases">0</b></div>
              <div class="shadow-mini"><span>Eligible</span><b id="shadowV3Eligible">0</b></div>
              <div class="shadow-mini"><span>Wins / Losses</span><b id="shadowV3WinLoss">0 / 0</b></div>
              <div class="shadow-mini"><span>False Rescue</span><b id="shadowV3False">0</b></div>
              <div class="shadow-mini"><span>Truth Block</span><b id="shadowV3TruthBlock">0</b></div>
              <div class="shadow-mini"><span>Top Cause</span><b id="shadowV3Cause">none</b></div>
            </div>
            <div class="shadow-note" style="padding:12px 0 0">No auto-deploy | wallet override shadow only | promotion requires positive closed evidence</div>
          </div>
          <div class="shadow-version-card">
            <div class="shadow-version-head">
              <div>
                <div class="shadow-version-title">AI Usage</div>
                <div class="shadow-version-sub">API cost breakdown</div>
              </div>
              <span class="tag tag-c" id="aiUsageMode">TODAY</span>
            </div>
            <div class="shadow-mini-grid">
              <div class="shadow-mini"><span>Today Calls</span><b id="aiUsageCalls">--</b></div>
              <div class="shadow-mini"><span>Today Cost</span><b id="aiUsageCost">--</b></div>
              <div class="shadow-mini"><span>Today Input</span><b id="aiUsageInput">--</b></div>
              <div class="shadow-mini"><span>Today Output</span><b id="aiUsageOutput">--</b></div>
              <div class="shadow-mini"><span>Today Total</span><b id="aiUsageTotal">--</b></div>
              <div class="shadow-mini"><span>Today Avg/Call</span><b id="aiUsageAvg">--</b></div>
              <div class="shadow-mini"><span>Month Cost</span><b id="aiUsageMonthCost">--</b></div>
              <div class="shadow-mini"><span>Month Calls</span><b id="aiUsageMonthCalls">--</b></div>
            </div>
            <div class="shadow-note" style="padding:12px 0 0" id="aiUsageUpdated">Data dari ai_usage.json</div>
          </div>
        </div>
      </div>

      <!-- LOGS -->
      <div id="page-logs" class="page">
        <div class="page-header">
          <div>
            <div class="page-title">Log Activity</div>
            <div class="page-sub">Real-time bot activity</div>
          </div>
          <button class="btn" onclick="loadLogs()">Refresh</button>
        </div>
        <div class="card">
          <div class="card-header"><span class="card-title">agent.log</span><span
              style="font-size:11px;color:var(--muted)" id="logCnt">--</span></div>
          <div style="padding:8px 0">
            <div class="log-wrap" id="logW">
              <div style="color:var(--muted);font-size:12px;text-align:center;padding:20px">Loading...</div>
            </div>
          </div>
        </div>
      </div>

    </main>
  </div>

  <script>
    // const API=(location.hostname==='localhost'||location.hostname==='127.0.0.1')?'http://localhost:3001':'';
    const API = '';
    let CAL = { year: new Date().getFullYear(), month: new Date().getMonth() };
    let PNL = {}, TRADES = [], DAILY_COUNTS = {}, startTime = null, mMs = 10 * 60 * 1000, sMs = 30 * 60 * 1000;

    async function get(ep) { const r = await fetch(API + ep); if (!r.ok) throw new Error(r.status); return r.json(); }
    async function post(ep) { const r = await fetch(API + ep, { method: 'POST' }); if (!r.ok) throw new Error(r.status); return r.json(); }
    function x(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
    function showErr(m) { const b = document.getElementById('errBox'); if (!b) return; b.textContent = 'WARN: ' + m; b.style.display = 'block'; setTimeout(() => b.style.display = 'none', 6000); }
    function activeDateKey() {
      const d = new Date();
      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    }

    async function toggleScanLog() {
      const panel = document.getElementById('scanPanel');
      if (!panel) return;
      panel.classList.toggle('open');
      if (panel.classList.contains('open')) await loadForensicScan();
    }

    async function loadForensicScan() {
      const date = activeDateKey();
      const sourceEl = document.getElementById('scanSource');
      const summaryEl = document.getElementById('scanSummary');
      const lossesEl = document.getElementById('scanLosses');
      if (sourceEl) sourceEl.textContent = `Loading ${date}...`;
      if (summaryEl) summaryEl.innerHTML = '';
      if (lossesEl) lossesEl.innerHTML = '<div style="color:var(--muted);font-size:12px;padding:8px">Loading forensic scan...</div>';
      try {
        const data = await get('/api/forensic-scan/daily?date=' + encodeURIComponent(date));
        renderForensicScan(data);
      } catch (e) {
        if (sourceEl) sourceEl.textContent = `scanning_log/daily/${date}.json`;
        if (lossesEl) lossesEl.innerHTML = '<div style="color:var(--red);font-size:12px;padding:8px">Failed to load forensic scan</div>';
      }
    }

    async function downloadForensicScan() {
      const date = activeDateKey();
      try {
        const data = await get('/api/forensic-scan/daily?date=' + encodeURIComponent(date));
        const payload = JSON.stringify(data, null, 2);
        const blob = new Blob([payload], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'meridian_scan_log_' + date + '.json';
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      } catch (e) {
        const panel = document.getElementById('scanPanel');
        const lossesEl = document.getElementById('scanLosses');
        if (panel) panel.classList.add('open');
        if (lossesEl) lossesEl.innerHTML = '<div style="color:var(--red);font-size:12px;padding:8px">Failed to download forensic scan</div>';
      }
    }

    function renderForensicScan(data = {}) {
      const sourceEl = document.getElementById('scanSource');
      const summaryEl = document.getElementById('scanSummary');
      const lossesEl = document.getElementById('scanLosses');
      const s = data.summary || {};
      if (sourceEl) sourceEl.textContent = data.source || `scanning_log/daily/${x(data.date || activeDateKey())}.json`;
      if (summaryEl) {
        const r = data.rejection_analysis || {};
        const kpis = [
          ['Trades', s.total_trades ?? 0],
          ['Profit', s.profit_count ?? 0],
          ['Loss', s.loss_count ?? 0],
          ['PF', s.pf ?? 0],
          ['OOR Above', s.oor_above ?? 0],
          ['OOR Below', s.oor_below ?? 0],
          ['Blocked', r.total_blocked ?? 0],
          ['Watch', r.total_watch ?? 0],
          ['Good Reject', r.good_rejections ?? 0],
          ['False Neg', r.false_negatives ?? 0],
          ['Unclear', r.unclear ?? 0],
        ];
        summaryEl.innerHTML = kpis.map(([k, v]) => `<div class="scan-kpi"><span>${x(k)}</span><b>${x(v)}</b></div>`).join('');
      }
      const losses = data.loss_analysis || [];
      const rejection = data.rejection_analysis || {};
      const rejects = rejection.items || [];
      if (!lossesEl) return;
      const rows = [];
      const now = new Date().toLocaleTimeString('id-ID', { hour12: false });
      const line = (tag, msg, cls = '') => rows.push(`<div class="scan-log-line"><span class="scan-log-time">${x(now)}</span><span class="scan-log-tag ${x(cls)}">${x(tag)}</span><span class="scan-log-msg">${x(msg)}</span></div>`);
      line('SUMMARY', `trades ${s.total_trades ?? 0} | profit ${s.profit_count ?? 0} | loss ${s.loss_count ?? 0} | pf ${s.pf ?? 0} | blocked ${rejection.total_blocked ?? 0} | watch ${rejection.total_watch ?? 0}`, 'profit');
      line('OOR', `above ${s.oor_above ?? 0} | below ${s.oor_below ?? 0}`, (s.oor_above || s.oor_below) ? 'watch' : '');
      for (const loss of losses) {
        const probs = loss.root_cause_probability || {};
        const sorted = Object.entries(probs).sort((a, b) => Number(b[1]) - Number(a[1])).slice(0, 5);
        line('LOSS', `${loss.pool || '--'} ${loss.loss_reason || '--'} | failure_stage ${loss.logic_failure_stage || '--'}`, 'loss');
        line('VERDICT', loss.verdict || '--', loss.logic_failure_stage === 'unavoidable variance' ? 'watch' : 'loss');
        line('ROOTCAUSE', sorted.map(([k, v]) => `${k}:${v}`).join(' | '), 'watch');
        if ((loss.timeline || []).length) line('TIMELINE', loss.timeline.join(' -> '));
      }
      if ((rejection.top_false_negative_causes || []).length) {
        line('FN_CAUSE', (rejection.top_false_negative_causes || []).map((c) => `${c.logic}:${c.count}`).join(' | '), 'false-negative');
      }
      for (const item of rejects.slice(0, 30)) {
        const reasons = (item.reasons || []).slice(0, 3).map((r) => r.value || r.logic).filter(Boolean).join(' | ');
        const cls = item.verdict === 'FALSE_NEGATIVE' ? 'false-negative' : item.verdict === 'GOOD_REJECTION' ? 'good-rejection' : 'unclear';
        line(item.status || 'REJECT', `${item.pool || '--'} | verdict ${item.verdict || 'UNCLEAR'} | stage ${item.rejection_stage || '--'}${item.likely_logic_failure ? ' | likely ' + item.likely_logic_failure : ''}`, cls);
        if (reasons) line('REASON', reasons, cls);
      }
      if (rows.length <= 2 && !losses.length && !rejects.length) {
        line('EMPTY', 'No losses or rejections recorded for active day yet.', 'watch');
      }
      lossesEl.innerHTML = rows.join('');
    }

    function renderAIBudgetAlert(ai) {
      const el = document.getElementById('aiBudgetAlert');
      if (!el) return;
      if (!ai || !ai.warn) {
        el.style.display = 'none';
        return;
      }
      const dailyLimit = Number(ai.dailyBudgetUsd || 0);
      const callLimit = Number(ai.maxCallsPerDay || 0);
      const dailyCost = '$' + Number(ai.dayCostUsd || 0).toFixed(4);
      const dailyText = dailyLimit > 0 ? dailyCost + ' / $' + dailyLimit : dailyCost;
      const callText = callLimit > 0 ? (ai.dayCalls || 0) + ' / ' + callLimit + ' calls' : (ai.dayCalls || 0) + ' calls';
      const pctText = ai.dailyCostPct != null ? ' | daily ' + Number(ai.dailyCostPct).toFixed(1) + '%' : '';
      const modeText = ai.mode ? ' | mode ' + ai.mode + (ai.remainingPct != null ? ' ' + Number(ai.remainingPct).toFixed(1) + '%' : '') : '';
      el.className = 'budget-alert' + (ai.blocked ? ' danger' : '');
      el.innerHTML = '<strong>' + (ai.blocked ? 'AI budget blocked' : 'AI budget warning') + '</strong>' +
        '<span>' + x(ai.reason || 'AI budget is near limit') + ' | ' + x(dailyText) + ' | ' + x(callText + pctText + modeText) + '</span>';
      el.style.display = 'flex';
    }

    function renderOperatorIntelligence(oi) {
      const health = oi?.health || {};
      const score = Number(health.score);
      const healthEl = document.getElementById('botHealth');
      const subEl = document.getElementById('botHealthSub');
      if (healthEl) {
        healthEl.textContent = Number.isFinite(score) ? score + '/100' : '--';
        healthEl.className = 'stat-value ' + (score >= 80 ? 'green' : score < 60 ? 'red' : '');
      }
      if (subEl) {
        subEl.textContent = health.label
          ? `${health.label} | WR ${Number(health.winRate || 0).toFixed(1)}% | OOR ${Number(health.oorRate || 0).toFixed(1)}%`
          : 'waiting for trades';
      }
      const alertEl = document.getElementById('operatorAlert');
      if (!alertEl) return;
      const alerts = oi?.alerts || [];
      if (!alerts.length) {
        alertEl.style.display = 'none';
        return;
      }
      const top = alerts[0];
      alertEl.className = 'budget-alert' + (top.severity === 'danger' ? ' danger' : '');
      alertEl.innerHTML = '<strong>Operator alert</strong><span>' + x(top.message || top.type) + '</span>';
      alertEl.style.display = 'flex';
    }

    function renderSmartWalletObserver(data = {}) {
      const status = String(data.status || 'HOLD').toUpperCase();
      const statusEl = document.getElementById('swoStatus');
      const reasonEl = document.getElementById('swoReason');
      const listEl = document.getElementById('swoWalletList');
      const summary = data.summary || {};
      if (statusEl) {
        statusEl.textContent = status;
        statusEl.className = 'observer-status ' + (status === 'READY' ? 'ready' : status === 'WATCH' ? 'watch' : 'hold');
      }
      const conf = Number(data.confidence || 0);
      document.getElementById('swoConf').textContent = Math.round(conf) + '%';
      document.getElementById('swoSamples').textContent = summary.sampleCount || 0;
      document.getElementById('swoWallets').textContent = summary.activeWallets || summary.totalWallets || 0;
      document.getElementById('swoPromising').textContent = summary.promisingWallets || 0;
      document.getElementById('swoEngine').textContent = data.engineUseAllowed ? 'ON' : 'OFF';
      if (reasonEl) {
        const generated = data.generatedAt ? new Date(data.generatedAt).toLocaleTimeString('id-ID', { hour12: false }) : '--';
        reasonEl.textContent = (data.reason || 'learning only') + ' | engine impact ' + (data.engineImpact || 'NONE') + ' | ' + generated;
      }
      const wallets = data.topWallets || [];
      if (!listEl) return;
      if (!wallets.length) {
        listEl.innerHTML = '<div class="observer-wallet"><div class="observer-wallet-name">Learning</div><div class="observer-wallet-sub">no smart-wallet samples yet | report only</div></div>';
        return;
      }
      listEl.innerHTML = wallets.slice(0, 12).map((w) => {
        const pnl = Number(w.pnlSol || 0);
        const pnlText = (pnl >= 0 ? '+' : '') + pnl.toFixed(4) + ' SOL';
        const pools = (w.topPools || []).slice(0, 2).map((p) => p.pool).join(', ') || '--';
        return `<div class="observer-wallet">
          <div class="observer-wallet-name">${x(w.name || w.short || 'wallet')}</div>
          <div class="observer-wallet-sub">score ${x(w.observerScore || 0)} | WR ${x(w.winRate || 0)}% | ${x(pnlText)}</div>
          <div class="observer-wallet-sub">${x(w.riskLabel || 'NEUTRAL')} | ${x(pools)}</div>
        </div>`;
      }).join('');
    }

    async function loadSmartWalletObserver() {
      try {
        renderSmartWalletObserver(await get('/api/smart-wallet-observer'));
      } catch (e) {
        renderSmartWalletObserver({ status: 'HOLD', confidence: 0, reason: 'observer API unavailable', engineImpact: 'NONE', summary: {}, topWallets: [] });
      }
    }

    async function downloadSmartWalletObserver() {
      const date = activeDateKey();
      try {
        const data = await get('/api/smart-wallet-observer');
        const payload = JSON.stringify(data, null, 2);
        const blob = new Blob([payload], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'meridian_smart_wallet_observer_' + date + '.json';
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      } catch (e) {
        renderSmartWalletObserver({ status: 'HOLD', confidence: 0, reason: 'observer download failed', engineImpact: 'NONE', summary: {}, topWallets: [] });
      }
    }

    function fmtUsdShort(value) {
      const n = Number(value);
      if (!Number.isFinite(n) || n <= 0) return '--';
      if (n >= 1000000) return '$' + (n / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
      if (n >= 1000) return '$' + (n / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
      return '$' + n.toFixed(0);
    }

    function renderMemeAlphaFinder(data = {}) {
      const status = String(data.status || 'HOLD').toUpperCase();
      const statusEl = document.getElementById('mafStatus');
      const reasonEl = document.getElementById('mafReason');
      const listEl = document.getElementById('mafList');
      const s = data.summary || {};
      const toneFor = (v) => {
        const label = String(v || '').toUpperCase();
        if (label === 'HOT' || label === 'RECLAIM_READY') return 'ready';
        if (label === 'HOT_LATE' || label === 'WATCH' || label === 'PULLBACK') return 'watch';
        if (label === 'DUMPED' || label === 'DANGER') return 'danger';
        return 'hold';
      };
      if (statusEl) {
        statusEl.textContent = status;
        statusEl.className = 'observer-status ' + toneFor(status);
      }
      document.getElementById('mafScanned').textContent = s.scannedProfiles || 0;
      document.getElementById('mafHot').textContent = (s.hot || 0) + ((s.hotLate || 0) ? ' +' + s.hotLate + ' late' : '');
      document.getElementById('mafWatch').textContent = (s.watch || 0) + ((s.reclaimReady || 0) ? ' +' + s.reclaimReady + ' reclaim' : '') + ((s.pullback || 0) ? ' +' + s.pullback + ' pullback' : '');
      document.getElementById('mafDanger').textContent = s.danger || 0;
      document.getElementById('mafEngine').textContent = data.engineUseAllowed ? 'ON' : 'OFF';
      if (reasonEl) {
        const generated = data.generatedAt ? new Date(data.generatedAt).toLocaleTimeString('id-ID', { hour12: false }) : '--';
        reasonEl.textContent = 'activity signal, not buy signal | buy/sell ' + (data.buySell || 'MANUAL_ONLY') + ' | ' + generated;
      }
      const candidates = data.candidates || [];
      if (!listEl) return;
      if (!candidates.length) {
        listEl.innerHTML = '<div class="observer-wallet"><div class="observer-wallet-name">No Candidate</div><div class="observer-wallet-sub">no meme alpha candidate in latest snapshot</div></div>';
        return;
      }
      listEl.innerHTML = candidates.slice(0, 6).map((c) => {
        const token = c.token || {};
        const m = c.market || {};
        const oracle = c.oracle || {};
        const om = oracle.metrics || {};
        const cls = toneFor(c.status);
        const url = token.dexUrl ? `<a href="${x(token.dexUrl)}" target="_blank" rel="noreferrer" style="color:var(--accent)">Dex</a>` : '';
        const chart = token.chartUrl ? `<details class="meme-chart"><summary>Chart</summary><iframe loading="lazy" src="${x(token.chartUrl)}"></iframe></details>` : '';
        const c5 = Number(m.priceChange5mPct || 0);
        const c1 = Number(m.priceChange1hPct || 0);
        const c6 = Number(m.priceChange6hPct || 0);
        return `<div class="observer-wallet">
          <div class="observer-wallet-name">${x(token.symbol || '--')} <span class="observer-status ${cls}" style="font-size:9px;padding:2px 5px">${x(c.status || 'HOLD')}</span></div>
          <div class="observer-wallet-sub">score ${x(c.score || 0)} | mcap ${x(fmtUsdShort(m.marketCapUsd))} | liq ${x(fmtUsdShort(m.liquidityUsd))}</div>
          <div class="observer-wallet-sub">vol5m ${x(fmtUsdShort(m.volume5mUsd))} | 5m ${x(c5.toFixed(1))}% | 1h ${x(c1.toFixed(1))}% | 6h ${x(c6.toFixed(1))}%</div>
          <div class="observer-wallet-sub">oracle ${x(oracle.phase || 'NO_CANDLE')} | ${x(oracle.action || 'WAIT')} | candle ${x(om.candlePct ?? '--')}% | high ${x(om.dumpFromHighPct ?? '--')}%</div>
          <div class="observer-wallet-sub">${x(token.shortAddress || '--')} ${url}</div>
          <div class="observer-wallet-sub" style="color:${cls === 'danger' ? 'var(--red)' : cls === 'watch' ? 'var(--yellow)' : 'var(--muted)'}">${x(c.entryHint || 'Report only. Check chart before manual buy.')}</div>
          <div class="observer-wallet-sub">${x(c.reason || '--')}</div>
          ${chart}
        </div>`;
      }).join('');
    }

    async function loadMemeAlphaFinder() {
      try {
        renderMemeAlphaFinder(await get('/api/meme-alpha-finder'));
      } catch (e) {
        renderMemeAlphaFinder({ status: 'HOLD', buySell: 'MANUAL_ONLY', summary: {}, candidates: [] });
      }
    }

    async function downloadMemeAlphaFinder() {
      const date = activeDateKey();
      try {
        const data = await get('/api/meme-alpha-finder');
        const payload = JSON.stringify(data, null, 2);
        const blob = new Blob([payload], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'meridian_meme_alpha_finder_' + date + '.json';
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      } catch (e) {
        renderMemeAlphaFinder({ status: 'HOLD', buySell: 'MANUAL_ONLY', summary: {}, candidates: [] });
      }
    }

    function impactClass(score) {
      const n = Number(score || 0);
      if (n > 70) return 'high';
      if (n >= 30) return 'watch';
      return 'bad';
    }

    function renderFeatureImpact(data) {
      const grid = document.getElementById('featureImpactGrid');
      if (!grid) return;
      const features = data?.features || [];
      const top = data?.summary?.topHelper;
      const aggressive = data?.summary?.mostAggressive;
      const updated = document.getElementById('featureImpactUpdated');
      const topEl = document.getElementById('featureTopHelper');
      const aggressiveEl = document.getElementById('featureMostAggressive');
      if (updated) updated.textContent = data?.summary?.updatedAt
        ? new Date(data.summary.updatedAt).toLocaleTimeString('id-ID', { hour12: false })
        : '--';
      if (topEl) topEl.textContent = top ? `Top Helper: ${top.label} (${top.estimatedSavedPct >= 0 ? '+' : ''}${top.estimatedSavedPct}%)` : 'Top Helper: --';
      if (aggressiveEl) aggressiveEl.textContent = aggressive ? `Most Aggressive: ${aggressive.label} (${aggressive.estimatedSavedPct >= 0 ? '+' : ''}${aggressive.estimatedSavedPct}%)` : 'Most Aggressive: --';
      if (!features.length) {
        grid.innerHTML = '<div style="color:var(--muted);font-size:12px;padding:8px">No feature impact samples yet</div>';
        return;
      }
      grid.innerHTML = features.map((f) => {
        const score = Math.max(0, Math.min(100, Number(f.effectivenessScore || 0)));
        const cls = impactClass(score);
        const saved = Number(f.estimatedSavedPct || 0);
        const falseBlock = Number(f.falseBlockEstimatePct || 0);
        return `<div class="impact-item">
          <div class="impact-top">
            <div class="impact-title">${x(f.label)}</div>
            <span class="tag ${cls === 'high' ? 'tag-open' : cls === 'bad' ? 'tag-d' : 'tag-dry'} impact-status">${x(f.status)}</span>
          </div>
          <div class="obar"><div class="bar-bg"><div class="bar-fill ${cls}" style="width:${score}%"></div></div><span class="mono" style="font-size:11px;min-width:30px">${score}</span></div>
          <div class="impact-meta">
            <span>Blocked<b>${Number(f.blockedCount || 0)}</b></span>
            <span>Passed<b>${Number(f.passedCount || 0)}</b></span>
            <span>Saved Est<b>${saved >= 0 ? '+' : ''}${saved}%</b></span>
            <span>False Block<b>${falseBlock}%</b></span>
            <span>Effectiveness<b>${score}</b></span>
            <span>Status<b>${x(f.status)}</b></span>
          </div>
        </div>`;
      }).join('');
    }

    function go(n, el) {
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      document.getElementById('page-' + n).classList.add('active');
      document.querySelectorAll('.nav-item').forEach(e => e.classList.remove('active'));
      if (el) el.classList.add('active');
      if (n === 'calendar') { loadPnl().then(() => renderCal()); }
      if (n === 'ranking') loadRanking();
      if (n === 'history') loadPnl();
      if (n === 'logs') loadLogs();
      if (n === 'pools') loadPools();
      if (n === 'alpha') { loadSmartWalletObserver(); loadMemeAlphaFinder(); }
      if (n === 'shadow') { loadShadowIntelligence(); loadAiUsage(); }
    }

    async function generateIncidentReport() {
      try {
        const r = await post('/api/incident-report/generate');
        if (r.ok && r.downloadUrl) {
          window.location.href = r.downloadUrl;
          showErr('Incident report generated and download started');
        } else {
          showErr(r.reason || 'No incident report generated');
        }
      } catch (e) {
        showErr('Incident report generation failed');
      }
    }

    async function loadStatus() {
      try {
        const d = await get('/api/status');
        const b = d.bot || {}, w = d.wallet || {};
        const rev = document.getElementById('revBadge');
        if (rev && d.dashboard?.label) rev.textContent = d.dashboard.label;
        renderAIBudgetAlert(d.aiBudget);
        renderOperatorIntelligence(d.operatorIntelligence);
        const aiModeEl = document.getElementById('aiMode');
        const aiModeSubEl = document.getElementById('aiModeSub');
        if (aiModeEl) {
          const aiMode = d.aiBudget?.mode || '--';
          aiModeEl.textContent = aiMode;
          aiModeEl.className = 'stat-value ' + (aiMode === 'NORMAL' ? 'green' : (aiMode === 'CRITICAL' || aiMode === 'ZERO_AI') ? 'red' : '');
        }
        if (aiModeSubEl) {
          const remaining = d.aiBudget?.remainingPct;
          const cacheEntries = d.aiBudget?.optimization?.cacheEntries;
          const effectiveCap = d.aiBudget?.effectiveDailyCallCap;
          aiModeSubEl.textContent = (remaining != null ? Number(remaining).toFixed(1) + '% left' : 'budget unknown') +
            (effectiveCap ? ' | cap ' + effectiveCap + '/day' : '') +
            (cacheEntries != null ? ' | cache ' + cacheEntries : '');
        }
        document.getElementById('sDot').className = 'status-dot' + (b.running ? ' live' : ' offline');
        document.getElementById('sTxt').textContent = b.running ? 'Bot running' : 'Bot offline';
        document.getElementById('sMode').textContent = b.mode || '--';
        document.getElementById('modeBadge').textContent = b.mode || '--';
        document.getElementById('modeBadge').className = 'badge ' + (b.mode === 'DRY RUN' ? 'badge-dry' : 'badge-live');
        document.getElementById('agentId').textContent = b.agentId ? 'Agent: ' + b.agentId : 'Meridian DLMM Bot';
        document.getElementById('solBal').textContent = (w.solBalance || 0).toFixed(4) + ' SOL';
        document.getElementById('solUsd').textContent = '$' + (w.usdValue || 0).toFixed(2);
        const ts = d.tradeStats || { total: 0, wins: 0, losses: 0, winRate: 0 };
        document.getElementById('winRate').textContent = ts.total > 0 ? (ts.winRate + '%') : '--';
        document.getElementById('scrCnt').textContent =
          ts.total + ' trades | ' + (b.screeningCount || 0) + ' screenings';
        const dw = d.signals?.weights || {};
        const dvals = Object.values(dw).map(Number).filter(Number.isFinite);
        const avgBoost = dvals.length ? (dvals.reduce((sum, v) => sum + v, 0) / dvals.length - 1) * 100 : 0;
        document.getElementById('darwinBoost').textContent = (avgBoost >= 0 ? '+' : '') + avgBoost.toFixed(1) + '%';
        document.getElementById('darwinBoost').className = 'stat-value ' + (avgBoost > 0 ? 'green' : avgBoost < 0 ? 'red' : '');
        document.getElementById('darwinSub').textContent = d.signals?.lastRecalc
          ? 'recalc #' + (d.signals?.recalcCount || 0)
          : 'waiting for samples';
        // Tag warna win rate
        const wrEl = document.getElementById('winRate');
        wrEl.className = 'stat-value' + (ts.total === 0 ? '' : ts.winRate >= 60 ? ' green' : ts.winRate >= 40 ? '' : ' red');
        document.getElementById('wAddr').textContent = w.address || '--';
        if (w.address) document.getElementById('scanLink').href = 'https://solscan.io/account/' + w.address;
        const pc = d.positions?.count || 0;
        document.getElementById('actPools').textContent = pc;
        document.getElementById('poolSub').textContent = pc > 0 ? pc + ' active' : b.mode === 'DRY RUN' ? 'dry run' : 'no positions';
        document.getElementById('mScr').textContent = b.screeningCount || 0;
        if (b.lastStartup && !startTime) startTime = new Date(b.lastStartup).getTime();
        // SIMULATION CAPITAL BADGE - utama SOL, USD sebagai subtext
        const sc = d.simCapital;
        if (sc && b.mode === 'DRY RUN') {
          document.getElementById('simCapBadge').style.display = 'block';
          const sp = sc.solPrice || 0;
          const usd = (sol) => '$' + (sol * sp).toFixed(2);
          document.getElementById('scInitial').textContent = sc.initial.toFixed(2) + ' SOL';
          document.getElementById('scInitialUsd').textContent = usd(sc.initial);
          document.getElementById('scCurrent').textContent = sc.current.toFixed(4) + ' SOL';
          document.getElementById('scCurrentUsd').textContent = usd(sc.current);
          const pnl = sc.pnl || 0;
          const pnlUsd = sc.pnlUsd || 0;
          const pct = sc.initial > 0 ? (pnl / sc.initial * 100) : 0;
          const pnlEl = document.getElementById('scPnl');
          const pctEl = document.getElementById('scPct');
          pnlEl.textContent = (pnl >= 0 ? '+' : '-') + Math.abs(pnl).toFixed(4) + ' SOL';
          pnlEl.style.color = pnl > 0 ? 'var(--green)' : pnl < 0 ? 'var(--red)' : 'var(--muted)';
          const usdStr = (pnlUsd >= 0 ? '+$' : '-$') + Math.abs(pnlUsd).toFixed(2);
          const pctStr = (pct >= 0 ? '+' : '') + pct.toFixed(2) + '%';
          const costStr = sc.costsUsd > 0 ? ' | costs $' + sc.costsUsd.toFixed(2) : '';
          pctEl.textContent = usdStr + ' | ' + pctStr + costStr;
          pctEl.style.color = pnlEl.style.color;
        }
      } catch (e) { showErr('Cannot reach backend - run: npm start in D:\\meridian-bot\\pool-dashboard'); }
    }

    async function loadPnl() {
      try {
        const d = await get('/api/pnl');
        PNL = d.daily || {};
        TRADES = d.trades || [];
        DAILY_COUNTS = buildDailyCounts(TRADES);
        const s = d.summary || {}, p = s.total || 0;
        const pu = s.totalUsd || 0;
        const usdIdr = Number(d.usdIdr || 0);
        const ps = (p >= 0 ? '+' : '-') + Math.abs(p).toFixed(4) + ' SOL';
        const psUsd = (pu >= 0 ? '+$' : '-$') + Math.abs(pu).toFixed(2);
        const psIdr = fmtIdrK(pu, usdIdr);
        document.getElementById('monthPnl').textContent = ps;
        document.getElementById('monthPnl').className = 'stat-value ' + (p >= 0 ? 'green' : 'red');
        const dp = Number(s.today || 0);
        const dpu = Number(s.todayUsd || 0);
        const dps = (dp >= 0 ? '+' : '-') + Math.abs(dp).toFixed(4) + ' SOL';
        const dpsUsd = (dpu >= 0 ? '+$' : '-$') + Math.abs(dpu).toFixed(2);
        const dpsIdr = fmtIdrK(dpu, usdIdr);
        const costIdr = fmtIdrK(s.costsUsd || 0, usdIdr);
        const profitText = psIdr ? psUsd + ' / ' + psIdr : psUsd;
        const costText = s.costsUsd > 0 ? ' | costs $' + s.costsUsd.toFixed(2) + (costIdr ? ' / ' + costIdr : '') : '';
        document.getElementById('tDays').textContent = profitText + costText + ' | ' + (s.tradingDays || 0) + ' trading days';
        const dailyPnlEl = document.getElementById('dailyPnl');
        dailyPnlEl.textContent = dps;
        dailyPnlEl.className = 'stat-value ' + (dp > 0 ? 'green' : dp < 0 ? 'red' : '');
        const todayCounts = DAILY_COUNTS[s.todayKey] || { wins: 0, losses: 0 };
        const dailyText = dpsIdr ? dpsUsd + ' / ' + dpsIdr : dpsUsd;
        const dailyParts = [x(s.todayKey || 'today'), x(dailyText)];
        if (todayCounts.wins > 0) dailyParts.push('<span style="color:#fff">win ' + x(todayCounts.wins) + 'x</span>');
        if (todayCounts.losses > 0) dailyParts.push('<span style="color:var(--red)">loss ' + x(todayCounts.losses) + 'x</span>');
        document.getElementById('dailyPnlSub').innerHTML = dailyParts.join(' | ');
        document.getElementById('mTotal').textContent = ps;
        document.getElementById('mTotal').className = 'mval ' + (p >= 0 ? 'g' : 'r');
        document.getElementById('mBest').textContent = '+' + (s.best || 0).toFixed(4) + ' SOL';
        document.getElementById('mWorst').textContent = '-' + Math.abs(s.worst || 0).toFixed(4) + ' SOL';
        document.getElementById('mDays').textContent = s.tradingDays || 0;
        renderTrades(d.tradeTotal || TRADES.length);
      } catch (e) { }
    }

    async function loadShadowIntelligence() {
      try {
        const [d, v2, v3] = await Promise.all([
          get('/api/shadow-intelligence'),
          get('/api/shadow-v2'),
          get('/api/shadow-v3-wallet-rescue'),
        ]);
        const s = d.summary || {};
        const s2 = v2.summary || {};
        const s3 = v3.summary || {};
        const status = String(s.status || 'LEARNING');
        const pnl = Number(s.shadow_pnl_sol || 0);
        const impact = Number(s.impact_ratio_pct || 0);
        const setText = (id, value) => {
          const el = document.getElementById(id);
          if (el) el.textContent = value;
        };
        const pnlEl = document.getElementById('shadowPnl');
