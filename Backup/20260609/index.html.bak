        const v3Mode = document.getElementById('shadowV3Mode');
        if (v3Mode) {
          v3Mode.textContent = v3Status;
          v3Mode.className = 'tag ' + (v3Status === 'CANDIDATE' ? 'tag-open' : v3Status === 'WATCH' ? 'tag-dry' : 'tag-d');
        }
        const v3PnlEl = document.getElementById('shadowV3Pnl');
        if (v3PnlEl) {
          v3PnlEl.textContent = (v3Pnl >= 0 ? '+' : '-') + Math.abs(v3Pnl).toFixed(4) + ' SOL';
          v3PnlEl.style.color = v3Pnl > 0 ? 'var(--green)' : v3Pnl < 0 ? 'var(--red)' : 'var(--text)';
        }
        setText('shadowV3Cases', String(s3.cases || 0));
        setText('shadowV3Eligible', String(s3.eligible_cases || 0));
        setText('shadowV3WinLoss', String(s3.rescue_wins || 0) + ' / ' + String(s3.rescue_losses || 0));
        setText('shadowV3False', String(s3.false_rescue_count || 0));
        setText('shadowV3TruthBlock', String(s3.truth_blocked_count || 0));
        setText('shadowV3Cause', s3.top_cause || 'none');
        setText('shadowUpdated', s.generated_at
          ? new Date(s.generated_at).toLocaleTimeString('id-ID', { hour12: false })
          : 'report only');
      } catch (e) { }
    }

   

    async function loadAiUsage() {
      try {
        const data = await get('/api/ai-usage');
        renderAiUsage(data);
      } catch (e) { }
    }

    function renderAiUsage(data) {
      if (!data || !data.today) return;
      const t = data.today, m = data.month;
      const s = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
      s('aiUsageCalls', t.calls);
      s('aiUsageCost', '$' + t.costUsd.toFixed(4));
      s('aiUsageInput', (t.inputTokens / 1000).toFixed(0) + 'K');
      s('aiUsageOutput', (t.outputTokens / 1000).toFixed(0) + 'K');
      s('aiUsageTotal', (t.totalTokens / 1000).toFixed(0) + 'K');
      s('aiUsageAvg', '$' + t.avgCostPerCall.toFixed(6));
      s('aiUsageMonthCost', '$' + m.costUsd.toFixed(4));
      s('aiUsageMonthCalls', m.calls);
      const updated = document.getElementById('aiUsageUpdated');
      if (updated) updated.textContent = 'today ' + t.date + ' | month ' + m.month;
    }
function dateKeyFromTrade(t) {
      const raw = t.closeTime || t.deployTime;
      if (!raw) return null;
      const d = new Date(raw);
      if (!Number.isFinite(d.getTime())) return null;
      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    }

    function buildDailyCounts(trades) {
      const out = {};
      for (const t of trades || []) {
        if (String(t.status || '').toLowerCase() !== 'closed') continue;
        const key = dateKeyFromTrade(t);
        if (!key) continue;
        const pnl = Number(t.pnlSol ?? t.pnlPct ?? t.pnlUsd);
        if (!Number.isFinite(pnl) || pnl === 0) continue;
        out[key] ||= { wins: 0, losses: 0 };
        if (pnl > 0) out[key].wins += 1;
        else out[key].losses += 1;
      }
      return out;
    }

    function fmtSol(v) {
      const n = Number(v);
      return Number.isFinite(n) ? n.toFixed(4) + ' SOL' : '--';
    }

    function fmtIdrK(usd, rate) {
      const amount = Number(usd) * Number(rate || 0);
      if (!Number.isFinite(amount) || !amount) return '';
      const k = amount / 1000;
      const text = Math.abs(k) >= 100 ? Math.round(Math.abs(k)).toString() : Math.abs(k).toFixed(1).replace(/\.0$/, '');
      return (amount < 0 ? '-Rp' : 'Rp') + text + 'K';
    }

    function fmtPct(v) {
      const n = Number(v);
      if (!Number.isFinite(n)) return '--';
      return (n >= 0 ? '+' : '') + n.toFixed(2) + '%';
    }

    function fmtDuration(mins) {
      const n = Number(mins);
      if (!Number.isFinite(n)) return '--';
      if (n < 60) return Math.max(0, Math.floor(n)) + 'm';
      const h = Math.floor(n / 60), m = Math.floor(n % 60);
      return h + 'h' + (m ? ' ' + m + 'm' : '');
    }

    function fmtDateTime(v) {
      if (!v) return '--';
      const d = new Date(v);
      if (!Number.isFinite(d.getTime())) return '--';
      return d.toLocaleString('id-ID', { hour12: false, month: 'short', day: '2-digit', hour: '2-digit', minute: '2-digit' });
    }

    function renderTrades(total) {
      const tb = document.getElementById('tradeBody');
      if (!tb) return;
      const cnt = document.getElementById('tradeCnt');
      if (cnt) cnt.textContent = (total || TRADES.length || 0) + ' deploys';
      if (!TRADES.length) {
        tb.innerHTML = '<tr><td colspan="10" style="text-align:center;color:var(--muted);padding:32px;font-size:12px">No deployments recorded yet</td></tr>';
        return;
      }
      tb.innerHTML = TRADES.map((t, i) => {
        const pnl = Number(t.pnlSol);
        const pct = Number(t.pnlPct);
        const pnlCls = Number.isFinite(pnl) ? (pnl > 0 ? 'num-pos' : pnl < 0 ? 'num-neg' : 'num-flat') : 'num-flat';
        const status = String(t.status || '').toLowerCase();
        const tagCls = status === 'open' ? 'tag-open' : status === 'closed' ? 'tag-c' : 'tag-d';
        const addr = t.poolAddress ? `<div class="pool-sub">${x(String(t.poolAddress).slice(0, 8))}...${x(String(t.poolAddress).slice(-6))}</div>` : '';
        const exitBin = t.exitBin != null ? Number(t.exitBin) : null;
        const entryBin = t.entryBin != null ? Number(t.entryBin) : null;
        const delta = Number.isFinite(exitBin) && Number.isFinite(entryBin) ? exitBin - entryBin : null;
        const exitDelta = Number.isFinite(delta) ? `<div class="pool-sub">${delta >= 0 ? '+' : ''}${delta} vs entry</div>` : '';
        const exitSide = t.exitSide ? `<div class="pool-sub">${x(t.exitSide)}</div>` : '';
        const exitPool = Number.isFinite(exitBin)
          ? `<span class="mono">${exitBin}</span>${exitDelta || exitSide}`
          : '<span class="mono" style="color:var(--muted)">N/A</span>';
        const bins = t.lowerBin != null && t.upperBin != null ? `<div class="pool-sub">bins ${x(t.lowerBin)} -> ${x(t.upperBin)}</div>` : '';
        const reason = t.reason ? x(t.reason) : '--';
        return `<tr>
          <td class="mono" style="color:var(--muted2);font-size:11px">${i + 1}</td>
          <td><div class="pool-name">${x(t.pool || 'Unknown')}</div>${addr}${bins}</td>
          <td><span class="tag ${tagCls}">${x(status || 'unknown')}</span><div style="margin-top:5px"><span class="tag tag-dry">${x(t.mode || 'DRY RUN')}</span></div></td>
          <td class="mono">${fmtSol(t.amountSol)}</td>
          <td class="mono">${x(t.strategy || '--')}</td>
          <td class="mono ${pnlCls}">${fmtSol(t.pnlSol)}<div style="font-size:10px;margin-top:2px">${fmtPct(pct)}</div></td>
          <td>${exitPool}</td>
          <td>${reason}</td>
          <td class="mono">${fmtDuration(t.minutesHeld)}</td>
          <td class="mono" style="color:var(--muted)">${fmtDateTime(t.closeTime || t.deployTime)}</td>
        </tr>`;
      }).join('');
    }

    async function loadRanking() {
      try {
        const d = await get('/api/ranking');
        const body = document.getElementById('rankBody');
        const cnt = document.getElementById('rankCnt');
        const entries = d.latest?.entries || [];
        if (cnt) {
          const when = d.latest?.ts ? new Date(d.latest.ts).toLocaleTimeString('id-ID', { hour12: false }) : 'never';
          cnt.textContent = entries.length + ' ranked | tracked ' + (d.walletsTracked || 0) + ' | ' + when;
        }
        if (!entries.length) {
          body.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--muted);padding:32px;font-size:12px">No ranking snapshot yet</td></tr>';
          return;
        }
        body.innerHTML = entries.map((w) => {
          const score = Number(w.score || 0);
          const scoreCls = score >= 70 ? 'num-pos' : score >= 45 ? 'num-flat' : 'num-neg';
          const short = w.address ? String(w.address).slice(0, 8) + '...' + String(w.address).slice(-6) : '--';
          const wr = Number(w.winRate);
          return `<tr>
            <td class="mono" style="color:var(--muted2);font-size:11px">${w.rank || '--'}</td>
            <td><div class="pool-name">${x(w.label || short)}</div><div class="pool-sub">${x(short)}</div></td>
            <td class="mono ${scoreCls}">${score.toFixed(0)}</td>
            <td><span class="tag ${score >= 70 ? 'tag-open' : 'tag-c'}">${x(w.grade || '--')}</span></td>
            <td class="mono">${Number(w.pnl7d || 0).toFixed(2)}</td>
            <td class="mono">${Number(w.pnl30d || 0).toFixed(2)}</td>
            <td class="mono">${Number(w.feesEarned || 0).toFixed(2)}</td>
            <td class="mono">${Number.isFinite(wr) ? wr.toFixed(1) + '%' : '--'}</td>
          </tr>`;
        }).join('');
      } catch (e) {
        const body = document.getElementById('rankBody');
        if (body) body.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--red);padding:32px;font-size:12px">Error loading ranking</td></tr>';
      }
    }

    async function loadPools() {
      try {
        const [d, copy] = await Promise.all([
          get('/api/pools'),
          get('/api/copy-signals?limit=10').catch(() => ({ signals: [] })),
        ]);
        const cands = d.candidates || [], dropped = d.dropped || [];
        const copySignals = (copy.signals || []).filter(s => String(s.action || '').toUpperCase() === 'COPY');
        const copyAll = [...(copy.signals || []), ...(copy.ignored || [])]
          .filter(s => s && (s.poolName || s.deployArgs?.pool_name || s.pool));
        const copyByPool = new Map();
        for (const s of copyAll) {
          const key = String(s.poolName || s.deployArgs?.pool_name || '').toUpperCase();
          if (!key) continue;
          const prev = copyByPool.get(key);
          const prevScore = Number(prev?.walletScore ?? prev?.deployArgs?.wallet_score);
          const nextScore = Number(s.walletScore ?? s.deployArgs?.wallet_score);
          if (!prev || (!Number.isFinite(prevScore) && Number.isFinite(nextScore))) copyByPool.set(key, s);
        }
        const topReject = dropped[0] || null;
        const decisionCounts = cands.reduce((acc, p) => {
          const label = p.roi?.status?.label || 'CANDIDATE';
          acc[label] = (acc[label] || 0) + 1;
          return acc;
        }, {});
        renderOffensiveEdge(d.offensive || {});
        renderExecutionIntelligence(d.execution || {});
        document.getElementById('poolCnt').textContent = cands.length > 0
          ? `${decisionCounts.CANDIDATE || 0} candidate, ${decisionCounts.WATCH || 0} watch, ${decisionCounts.BLOCKED || 0} blocked`
          : copySignals.length > 0
            ? '0 screener, ' + copySignals.length + ' copy signals'
          : '0 eligible, ' + dropped.length + ' rejected';
        const all = cands.slice(0, 4);
        const tb = document.getElementById('poolBody');
        tb.innerHTML = all.length === 0
          ? (copySignals.length
            ? copySignals.slice(0, 5).map(s => {
              const roi = s.roi || {};
              const conf = Math.round(Number(s.confidence || 0) * 100);
              const score = Number(s.walletScore || s.deployArgs?.wallet_score || 0);
              const organic = Number(s.organicScore ?? s.deployArgs?.organic_score ?? 0);
              const feeTvl = Number(s.feeTvlRatio ?? s.deployArgs?.fee_tvl_ratio);
              const alphaEdge = s.alphaEdge || s.deployArgs?.alpha_edge || {};
              const alphaAction = alphaEdge.action || s.alphaAction || s.action || '--';
              const statusInfo = roi.status || fallbackStatus(roi.alpha?.state || alphaAction);
              const shownConf = Number.isFinite(Number(roi.confidence?.total)) ? Number(roi.confidence.total) : conf;
              const br = s.breakdown || s.confidenceBreakdown || {};
              const parts = ['wallet', 'range', 'fee_tvl', 'organic', 'volatility']
                .filter(k => br[k] != null)
                .map(k => k.replace('_', '/') + ' ' + Math.round(Number(br[k]) * 100) + '%')
                .join(' | ');
              const reasons = (s.reasons || []).slice(0, 4).join(' | ');
              const risks = (s.risks || []).length ? (s.risks || []).join(' | ') : 'LOW';
              const shadow = s.shadow ? `shadow ${x(s.shadow.action)}${s.shadow.wouldDiffer ? ' differs' : ''}` : '';
              const alpha = s.alphaEdge ? `alpha ${x(s.alphaRank || s.alphaEdge.alphaRank || '?')} (${x(s.alphaScore || s.alphaEdge.alphaScore || '?')})` : '';
              const ts = s.ts ? new Date(s.ts).toLocaleTimeString('id-ID', { hour12: false }) : '';
              return `<tr>
          <td><div class="pool-name">${x(s.poolName || s.deployArgs?.pool_name || 'copy pool')}</div><div class="pool-sub">${alpha ? x(alpha) : ''}${poolOrganicBadge(organic)}${ts ? ' | ' + x(ts) : ''}</div>${reasonLine(statusInfo)}${s.deployResult?.blocked ? '<div class="reason-line blocked" title="' + x(s.deployResult.reason || '') + '">❌ BLOCKED: ' + x(s.deployResult.reason || 'unknown') + '</div>' : s.deployResult?.error ? '<div class="reason-line blocked">❌ ERROR: ' + x(s.deployResult.error) + '</div>' : ''}${parts ? `<details class="pool-sub"><summary>why ${shownConf}%</summary><div>${x(parts)}</div><div>risk: ${x(risks)}</div>${reasons ? `<div>${x(reasons)}</div>` : ''}${shadow ? `<div>${shadow}</div>` : ''}${s.alphaEdge ? `<div>survival ${x(s.alphaEdge.survival?.score)} | crowd ${x(s.alphaEdge.crowd?.score)} | euphoria ${x(s.alphaEdge.euphoria?.score)} | expectancy ${x(s.alphaEdge.expectancy?.score)}</div>` : ''}</details>` : ''}</td>
          <td>${edgeCell(s.offensive)}</td>
          <td>${executionCell(s.execution)}</td>
          <td>${walletCell(score, roi.wallet)}</td>
          <td>${organicCell(organic, roi.organicTrend)}</td>
          <td>${feeTvlCell(feeTvl, roi.feeTvl)}</td>
          <td>${alphaBadge(roi.alpha?.state || alphaAction, roi.alpha)}</td>
          <td>${confidenceCell(shownConf, roi.confidence)}</td>
          <td>${statusTag(statusInfo)}</td>
        </tr>`;
            }).join('')
            : `<tr><td colspan="9" style="text-align:center;color:var(--muted);padding:24px;font-size:12px">No eligible pools right now${topReject ? `<div style="margin-top:6px;color:var(--red);font-family:var(--mono);font-size:11px">Top reject: ${x(topReject.name || 'pool')} - ${x(topReject.reason || 'filtered')}</div>` : ''}</td></tr>`)
          : all.map(p => {
            const copyMatch = copyByPool.get(String(p.name || '').toUpperCase()) || {};
            const view = selectDefensiveView(p, copyMatch);
            const organic = Number(p.organic || 0);
            const conf = p.confidence != null ? Math.round(Number(p.confidence || 0) * 100) : Number(p.poolScore || 0);
            const isDrop = false;
            const walletScore = Number(view.walletScore ?? view.deployArgs?.wallet_score ?? p.walletScore ?? p.poolScore);
            const copyOrganic = Number(view.organicScore ?? view.deployArgs?.organic_score);
            const feeTvl = Number(view.feeTvlRatio ?? view.deployArgs?.fee_tvl_ratio ?? feeRatioFromText(p.feeAtvl));
            const alphaEdge = view.alphaEdge || view.deployArgs?.alpha_edge || {};
            const alphaAction = alphaEdge.action || view.alphaAction || (view.action && String(view.action).toUpperCase() !== 'SKIP' ? view.action : (p.status === 'candidate' ? 'PASS' : '--'));
            const roi = view.roi || {};
            const statusInfo = roi.status || fallbackStatus(roi.alpha?.state || alphaAction);
            const displayOrganic = Number.isFinite(copyOrganic) && copyOrganic > 0 ? copyOrganic : organic;
            const shownConf = Number.isFinite(Number(roi.confidence?.total)) ? Number(roi.confidence.total) : conf;
            const poolSub = [
              p.vol ? x(p.vol) : '',
              p.tvl ? 'size ' + x(p.tvl) : '',
              poolOrganicBadge(displayOrganic),
            ].filter(Boolean).join(' | ');
            return `<tr>
          <td><div class="pool-name">${x(p.name || '--')}</div>${p.reason ? `<div style="font-size:10px;color:var(--red);margin-top:1px">${x(p.reason)}</div>` : `${poolSub ? `<div class="pool-sub">${poolSub}</div>` : ''}`}${reasonLine(statusInfo)}</td>
          <td>${edgeCell(view.offensive)}</td>
          <td>${executionCell(view.execution)}</td>
          <td>${walletCell(walletScore, roi.wallet)}</td>
          <td>${organicCell(displayOrganic, roi.organicTrend)}</td>
          <td>${feeTvlCell(feeTvl, roi.feeTvl)}</td>
          <td>${alphaBadge(roi.alpha?.state || alphaAction, roi.alpha)}</td>
          <td>${confidenceCell(shownConf, roi.confidence)}</td>
          <td>${statusTag(statusInfo)}</td>
        </tr>`;
          }).join('');
        const tf = document.getElementById('poolFull');
        if (!cands.length && !dropped.length) { tf.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--muted);padding:32px;font-size:12px">No pool data yet</td></tr>'; return; }
        let h = '';
        if (cands.length) { h += `<tr><td colspan="7" class="sec-sep">Screener Output (${cands.length})</td></tr>`; cands.forEach((p, i) => h += pr(p, i + 1, 'c')); }
        if (dropped.length) { h += `<tr><td colspan="7" class="sec-sep">Dropped by Filter (${dropped.length})</td></tr>`; dropped.forEach((p, i) => h += pr(p, cands.length + i + 1, 'd')); }
        tf.innerHTML = h;
      } catch (e) { console.error('pools:', e); }
    }

    async function loadFeatureImpact() {
      try {
        const d = await get('/api/feature-impact');
        renderFeatureImpact(d);
      } catch (e) {
        const grid = document.getElementById('featureImpactGrid');
        if (grid) grid.innerHTML = '<div style="color:var(--red);font-size:12px;padding:8px">Error loading feature impact</div>';
      }
    }

    function pr(p, i, s) {
      const ts = p.ts ? new Date(p.ts).toLocaleTimeString('id-ID', { hour12: false }) : '';
      const score = Number(p.poolScore ?? p.score);
      const confidenceRaw = Number(p.confidence);
      const confidencePct = Number.isFinite(confidenceRaw)
        ? (confidenceRaw <= 1 ? Math.round(confidenceRaw * 100) : Math.round(confidenceRaw))
        : null;
      const roi = p.roi || {};
      const shownConfidence = Number.isFinite(Number(roi.confidence?.total)) ? Number(roi.confidence.total) : confidencePct;
      const grade = p.grade || '--';
      return `<tr>
    <td style="color:var(--muted2);font-family:var(--mono);font-size:11px">${i}</td>
    <td><div class="pool-name">${x(p.name || '--')}</div>${p.reason ? `<div style="font-size:10px;color:var(--red);margin-top:2px">${x(p.reason)}</div>` : ''}${ts ? `<div style="font-size:10px;color:var(--muted2);margin-top:2px">${ts}</div>` : ''}${reasonLine(roi.status)}</td>
    <td style="font-family:var(--mono);font-size:12px">${Number.isFinite(score) ? score : '--'}</td>
    <td>${shownConfidence != null ? confidenceCell(shownConfidence, roi.confidence) : '<span style="color:var(--muted2)">--</span>'}</td>
    <td><span class="tag ${s === 'c' ? 'tag-c' : 'tag-d'}">${x(grade)}</span></td>
    <td>${organicCell(p.organic, roi.organicTrend)}</td>
    <td>${statusTag(roi.status || fallbackStatus(s === 'c' ? 'PASS' : 'AVOID'))}</td>
  </tr>`;
    }

    function organicBadge(value, enabled = true) {
      const organic = Number(value);
      if (!enabled || !Number.isFinite(organic) || organic <= 0) return '<span style="color:var(--muted2)">--</span>';
      const rounded = Math.round(organic);
      const tone = rounded >= 80 ? 'good' : rounded >= 60 ? 'watch' : 'bad';
      return `<span class="organic-badge"><span class="organic-dot ${tone}"></span><span>Organic ${x(rounded)}</span></span>`;
    }

    function feeRatioFromText(value) {
      const match = String(value || '').match(/-?\d+(?:\.\d+)?/);
      if (!match) return null;
      return Number(match[0]) / 100;
    }

    function metricTone(value, type) {
      const n = Number(value);
      if (!Number.isFinite(n)) return '';
      if (type === 'fee') return n >= 0.3 ? 'good' : n >= 0.08 ? 'watch' : 'bad';
      if (type === 'confidence') return n >= 70 ? 'good' : n >= 55 ? 'watch' : 'bad';
      return n >= 60 ? 'good' : n >= 45 ? 'watch' : 'bad';
    }

    function metricBadge(value, type) {
      const n = Number(value);
      if (!Number.isFinite(n) || n <= 0) return '<span style="color:var(--muted2)">--</span>';
      const label = type === 'fee' ? n.toFixed(2) : type === 'confidence' ? Math.round(n) + '%' : String(Math.round(n));
      return `<span class="metric-badge"><span>${x(label)}</span><span class="organic-dot ${metricTone(n, type)}"></span></span>`;
    }

    function severityRank(item = {}) {
      const label = item.roi?.status?.label || '';
      const alpha = item.roi?.alpha?.state || '';
      if (label === 'BLOCKED' || alpha === 'AVOID') return 3;
      if (label === 'WATCH' || alpha === 'HOLD') return 2;
      return 1;
    }

    function selectDefensiveView(pool = {}, copy = {}) {
      if (!copy || !copy.roi) return pool;
      return severityRank(copy) >= severityRank(pool) ? { ...pool, ...copy, name: pool.name || copy.poolName } : pool;
    }

    function edgeCell(offensive = {}) {
      const score = Number(offensive.edgeScore?.score);
      if (!Number.isFinite(score)) return '<span style="color:var(--muted2)">--</span>';
      const tier = offensive.edgeScore?.tier || edgeTier(score);
      const parts = offensive.edgeScore?.parts || {};
      const title = roiTitle(
        [`Edge ${Math.round(score)}`, tier.label || '', `Wallet ${parts.wallet ?? '--'}`, `Organic ${parts.organic ?? '--'}`, `FeeTVL ${parts.feeTvl ?? '--'}`, `Conf ${parts.confidence ?? '--'}`],
        offensive.explanation?.reasons || [],
        offensive.explanation?.warnings || [],
        offensive.integrity?.violations || [],
        offensive.entryTiming?.reasons || []
      );
      const integrity = offensive.integrity && offensive.integrity.valid === false
        ? `<div class="metric-sub avoid">SIGNAL INVALID</div>`
        : '';
      return `<div title="${x(title)}">${metricBadge(score, 'confidence')}<div class="metric-sub ${x(tier.tone || '')}">${x(tier.label || 'EDGE')}</div>${integrity}<div class="entry-sub">${timingBadge(offensive.entryTiming, true)}</div></div>`;
    }

    function executionCell(execution = {}) {
      const conviction = execution.conviction || {};
      const size = execution.positionSize || {};
      const state = execution.executionState || {};
      const portfolio = execution.portfolioAllocation || {};
      const rr = execution.riskReward || {};
      if (!conviction.state) return '<span style="color:var(--muted2)">--</span>';
      const displaySize = portfolio.label || size.label || '0%';
      const displayState = portfolio.executionState || state.state || '--';
      const title = roiTitle(
        [`Conviction ${conviction.score ?? '--'}`, `Adjusted size ${displaySize}`, `Raw size ${size.label || '--'}`, displayState, `Budget ${portfolio.budgetState || '--'}`, `RR ${rr.label || '--'}`],
        conviction.reasons || [],
        state.reasons || [],
        rr.reasons || []
      );
      const tone = conviction.state === 'NO TRADE' ? 'avoid' : conviction.state === 'EXTREME' || conviction.state === 'HIGH' ? 'strong' : conviction.state === 'MEDIUM' ? 'good' : 'weak';
      const stateTone = displayState === 'NO ENTRY' ? 'avoid' : displayState === 'SMALL TEST POSITION' ? 'weak' : tone;
      return `<div title="${x(title)}"><span class="metric-badge"><span>${x(displaySize)}</span><span class="organic-dot ${stateTone === 'strong' ? 'good' : stateTone === 'avoid' ? 'bad' : 'watch'}"></span></span><div class="metric-sub ${x(tone)}">${x(conviction.state)}</div><div class="metric-sub ${x(stateTone)}">${x(displayState)}</div><div class="metric-sub ${x(tone)}">RR ${x(rr.label || '--')}</div></div>`;
    }

    function edgeTier(score) {
      const n = Number(score);
      if (n >= 85) return { label: 'ELITE EDGE', tone: 'elite' };
      if (n >= 75) return { label: 'STRONG EDGE', tone: 'strong' };
      if (n >= 60) return { label: 'GOOD EDGE', tone: 'good' };
      if (n >= 45) return { label: 'WEAK EDGE', tone: 'weak' };
      return { label: 'AVOID EDGE', tone: 'avoid' };
    }

    function timingBadge(timing = {}, withPrefix = false) {
      const state = timing.state || 'WAIT';
      const label = withPrefix ? `ENTRY ${state}` : state;
      return `<span class="timing-badge ${x(timing.tone || 'watch')}" title="${x(roiTitle(timing.reasons || []))}">${x(label)}</span>`;
    }

    function renderOffensiveEdge(offensive = {}) {
      const top = offensive.topOpportunities || [];
      const regime = offensive.marketRegime || {};
      const topEl = document.getElementById('topOpps');
      const regimeEl = document.getElementById('marketRegime');
      const cntEl = document.getElementById('regimeCnt');
      if (cntEl) cntEl.textContent = regime.state ? `${regime.state} market` : '--';
      if (regimeEl) {
        regimeEl.innerHTML = `<span class="regime-state">${x(regime.state ? regime.state + ' MARKET' : '--')}</span><span>candidate ${x(regime.candidateCount ?? '--')}</span><span>watch ${x(regime.watchCount ?? '--')}</span><span>blocked ${x(regime.blockedCount ?? '--')}</span>`;
      }
      if (!topEl) return;
      if (!top.length) {
        topEl.innerHTML = '<div style="color:var(--muted);font-size:12px;padding:8px">No ranked opportunities</div>';
        return;
      }
      topEl.innerHTML = top.slice(0, 3).map((p) => {
        const reasons = (p.explanation?.reasons || []).slice(0, 3);
        const warnings = (p.explanation?.warnings || []).slice(0, 2);
        return `<div class="top-opp">
          <div class="top-opp-head"><span class="top-rank">#${x(p.rank)}</span><span class="top-edge">Edge ${x(p.edgeScore?.score ?? '--')}</span></div>
          <div class="pool-name">${x(p.name || '--')}</div>
          <div class="metric-sub ${x((p.edgeScore?.tier || edgeTier(p.edgeScore?.score)).tone || '')}">${x((p.edgeScore?.tier || edgeTier(p.edgeScore?.score)).label || 'EDGE')}</div>
          <div style="margin-top:7px">${timingBadge(p.entryTiming, true)}</div>
          ${p.execution?.portfolioAllocation ? `<div class="metric-sub weak">EXEC ${x(p.execution.portfolioAllocation.executionState)} / ${x(p.execution.portfolioAllocation.label)}</div>` : ''}
          <div class="top-why">
            ${reasons.map(r => `<span class="good">WHY TOP: ${x(r)}</span>`).join('')}
            ${warnings.map(r => `<span class="warn">WATCH: ${x(r)}</span>`).join('')}
          </div>
        </div>`;
      }).join('');
    }

    function renderExecutionIntelligence(execution = {}) {
      const risk = execution.riskBudget || {};
      const allocation = execution.capitalAllocation || [];
      const stateEl = document.getElementById('riskBudgetState');
      const summaryEl = document.getElementById('execSummary');
      const allocEl = document.getElementById('capitalAllocation');
      if (stateEl) stateEl.textContent = risk.state ? `${risk.state}` : '--';
      if (summaryEl) {
        summaryEl.innerHTML = `
          <div class="exec-kpi"><span>Risk</span><b>${x(risk.state || '--')}</b></div>
          <div class="exec-kpi"><span>Exposure</span><b>${x(risk.riskExposurePct ?? '--')}%</b></div>
          <div class="exec-kpi"><span>Executable</span><b>${x(risk.executableCount ?? '--')}</b></div>
          <div class="exec-kpi"><span>Blocked</span><b>${x(risk.excludedBlocked ?? '--')}</b></div>`;
      }
      if (!allocEl) return;
      if (!allocation.length) {
        allocEl.innerHTML = '<div style="color:var(--muted);font-size:12px;padding:4px">No executable allocation</div>';
        return;
      }
      allocEl.innerHTML = allocation.slice(0, 5).map((p) => `<div class="allocation-row"><span>${x(p.rank)}. ${x(p.name)}</span><b>${x(p.suggestedPct)}%</b><span>${x(p.executionState)}</span></div>`).join('');
    }

    async function loadMomentumRider() {
      try {
        const data = await get('/api/momentum-rider');
        renderMomentumRider(data);
      } catch (e) {
        const el = document.getElementById('momentumRiderDetail');
        if (el) el.innerHTML = '<div style="color:var(--red);font-size:12px;padding:4px">Fast market mode unavailable</div>';
      }
    }

    function renderMomentumRider(data = {}) {
      const stateEl = document.getElementById('fastMarketState');
      const summaryEl = document.getElementById('momentumRiderSummary');
      const detailEl = document.getElementById('momentumRiderDetail');
      const stats = data.stats || {};
      const decision = data.marketDecision || {};
      const range = decision.rangePlan || {};
      const anti = decision.antiOor || {};
      if (stateEl) stateEl.textContent = data.status || '--';
      if (summaryEl) {
        summaryEl.innerHTML = `
          <div class="exec-kpi"><span>Mode</span><b>${x(data.status || '--')}</b></div>
          <div class="exec-kpi"><span>Trades</span><b>${x(stats.totalTrades ?? 0)}</b></div>
          <div class="exec-kpi"><span>PF</span><b>${x(stats.pf ?? 0)}</b></div>
          <div class="exec-kpi"><span>OOR</span><b>${x(stats.oorRate ?? 0)}%</b></div>`;
      }
      if (!detailEl) return;
      const checks = (decision.activationChecks || []).map((c) => `${c.passed === true ? 'PASS' : c.passed === false ? 'BLOCK' : 'WAIT'} ${c.key}: ${c.detail ?? '--'}`);
      detailEl.innerHTML = `
        <div class="allocation-row"><span>Strategy</span><b>${x(decision.strategy || 'momentum_rider')}</b><span>${x(data.mode || 'SANDBOX_ONLY')}</span></div>
        <div class="allocation-row"><span>Range</span><b>${x(range.binsBelow ?? '--')} below</b><span>${x(range.binsAbove ?? '--')} above</span></div>
        <div class="allocation-row"><span>Momentum</span><b>${x(anti.momentumState || '--')}</b><span>${x(anti.oorRisk || '--')}</span></div>
        <div style="font-size:10px;color:var(--muted);font-family:var(--mono);line-height:1.5;padding:4px">${x(decision.reason || data.currentDeployLimitation || '--')}</div>
        <div style="font-size:10px;color:var(--muted2);font-family:var(--mono);line-height:1.5;padding:4px">${x(checks.slice(0, 6).join(' | '))}</div>`;
    }

    function fallbackStatus(action) {
      let label = String(action || '').toUpperCase();
      if (label === 'AVOID') return { label: 'BLOCKED', tone: 'blocked', reasonLabel: 'WHY BLOCKED', reasons: ['alpha decision AVOID'] };
      if (label === 'HOLD' || label === 'SKIP') return { label: 'WATCH', tone: 'watch', reasonLabel: 'WHY HOLD', reasons: ['alpha decision HOLD'] };
      return { label: 'CANDIDATE', tone: 'candidate', reasonLabel: 'WHY PASS', reasons: ['alpha decision PASS'] };
    }

    function statusTag(status = {}) {
      const label = status.label || 'CANDIDATE';
      const tone = status.tone || (label === 'BLOCKED' ? 'blocked' : label === 'WATCH' ? 'watch' : 'candidate');
      const cls = tone === 'blocked' ? 'tag-d' : tone === 'watch' ? 'tag-dry' : 'tag-c';
      const title = roiTitle(status.reasons || []);
      return `<span class="tag ${cls}" title="${x(title)}">${x(label)}</span>`;
    }

    function reasonLine(status = {}) {
      const reasons = (status.reasons || []).filter(Boolean);
      if (!reasons.length) return '';
      const tone = status.tone || 'candidate';
      const label = status.reasonLabel || (status.label === 'BLOCKED' ? 'WHY BLOCKED' : status.label === 'WATCH' ? 'WHY HOLD' : 'WHY PASS');
      const visible = reasons.slice(0, 3).join(' | ');
      return `<div class="reason-line ${x(tone)}" title="${x(roiTitle(reasons))}">${x(label)}: ${x(visible)}</div>`;
    }

    function organicCell(value, trend = {}) {
      const state = trend.state || '';
      const tone = state === 'ACCELERATING' ? 'accelerating' : state === 'DECELERATING' ? 'decelerating' : state ? 'stable' : '';
      const title = roiTitle(trend.drivers || [], trend.warnings || []);
      return `<div title="${x(title)}">${metricBadge(value, 'organic')}${state ? `<div class="metric-sub ${tone}">${x(state)}</div>` : ''}</div>`;
    }

    function roiTitle(...groups) {
      return groups.flat().filter(Boolean).join('\n');
    }

    function walletCell(score, wallet = {}) {
      const cls = wallet.classification || {};
      const title = roiTitle(wallet.strengths || [], wallet.risks || [], (wallet.penalty?.penalties || []).map(p => p.reason));
      return `<div title="${x(title)}">${metricBadge(wallet.adjustedScore ?? score, 'wallet')}${cls.label ? `<div class="metric-sub ${x(cls.tone || '')}">${x(cls.label)}</div>` : ''}</div>`;
    }

    function feeTvlCell(value, fee = {}) {
      const cls = fee.classification || {};
      const title = roiTitle(fee.strengths || [], fee.warnings || []);
      const trend = fee.trend ? (fee.trend === 'Improving' ? 'up' : fee.trend === 'Weakening' ? 'down' : 'stable') : '';
      return `<div title="${x(title)}">${metricBadge(fee.value ?? value, 'fee')}${cls.label ? `<div class="metric-sub ${x(cls.tone || '')}">${x(cls.label)}${trend ? ' / ' + x(trend) : ''}</div>` : ''}</div>`;
    }

    function confidenceCell(value, confidence = {}) {
      const parts = confidence.parts || {};
      const display = Number.isFinite(Number(confidence.total)) ? Number(confidence.total) : value;
      const rows = [
        ['Wallet', parts.wallet],
        ['Organic', parts.organic],
        ['FeeTVL', parts.feeTvl],
        ['AntiCrowd', parts.antiCrowd],
        ['Survival', parts.survival],
      ].filter(([, v]) => Number.isFinite(Number(v)));
      const corrections = (confidence.corrections || []).map((c) => ['Fix', c]);
      if (!rows.length && !corrections.length) return metricBadge(display, 'confidence');
      return `<details class="conf-breakdown"><summary>${metricBadge(display, 'confidence')}</summary><div class="conf-lines">${rows.map(([k, v]) => `<div><span>${x(k)}</span><b>${x(v)}%</b></div>`).join('')}${corrections.map(([k, v]) => `<div><span>${x(k)}</span><b>${x(v)}</b></div>`).join('')}</div></details>`;
    }

    function poolOrganicBadge(value) {
      const n = Number(value);
      if (!Number.isFinite(n) || n <= 0) return '';
      return `<span class="pool-organic-badge"><span>Organic ${x(Math.round(n))}</span><span class="organic-dot ${metricTone(n, 'organic')}"></span></span>`;
    }

    function alphaBadge(action, alpha = {}) {
      let label = String(action || '--').toUpperCase();
      if (!['PASS', 'HOLD', 'AVOID'].includes(label)) label = label === 'COPY' ? 'PASS' : label === 'SKIP' ? 'HOLD' : '--';
      if (label === '--') return '<span style="color:var(--muted2)">--</span>';
      const tone = label === 'PASS' ? 'good' : label === 'HOLD' ? 'watch' : 'bad';
      const title = roiTitle(alpha.explanation || []);
      return `<span class="metric-badge" title="${x(title)}"><span>${x(label)}</span><span class="organic-dot ${tone}"></span></span>`;
    }

    const SKIP = new Set(['POSITIONS']);
    const KT = ['STARTUP', 'CRON', 'ERROR', 'CRON_ERROR', 'HIVEMIND_WARN', 'SCREENING', 'AGENT', 'INIT', 'SHUTDOWN'];

    async function loadLogs() {
      try {
        const d = await get('/api/logs?limit=200');
        const logs = d.logs || [];
        document.getElementById('logCnt').textContent = (d.total || 0) + ' lines total';
        const w = document.getElementById('logW');
        const fl = logs.filter(l => !SKIP.has(l.tag));
        if (!fl.length) { w.innerHTML = '<div style="color:var(--muted);font-size:12px;text-align:center;padding:20px">No logs to show</div>'; return; }
        w.innerHTML = fl.map(l => {
          const isE = l.tag && l.tag.includes('ERROR'), isW = l.tag && l.tag.includes('WARN');
          const t = l.ts ? new Date(l.ts).toLocaleTimeString('id-ID', { hour12: false }) : '--';
          const tc = KT.includes(l.tag) ? 'lt-' + l.tag : 'lt-other';
          return `<div class="log-line"><span class="log-time">${t}</span><span class="log-tag ${tc}">${x(l.tag || 'INFO')}</span><span class="log-msg ${isE ? 'err' : isW ? 'warn' : ''}">${x(l.msg || '')}</span></div>`;
        }).join('');
        w.scrollTop = w.scrollHeight;
      } catch (e) { document.getElementById('logW').innerHTML = '<div style="color:var(--red);font-size:12px;text-align:center;padding:20px">Error loading logs</div>'; }
    }

    const MO = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
    const DA = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

    function renderCal() {
      const y = CAL.year, m = CAL.month;
      document.getElementById('calT').textContent = MO[m] + ' ' + y;
      const g = document.getElementById('calG');
      const isMobile = document.documentElement.classList.contains('is-mobile');
      const hdrs = isMobile ? DA.slice(0, 5) : DA;
      g.innerHTML = hdrs.map(d => `<div class="cdl">${d}</div>`).join('');
      let off = (new Date(y, m, 1).getDay() + 6) % 7;
      if (isMobile && off >= 5) off = 0;7;
      const days = new Date(y, m + 1, 0).getDate();
      const today = new Date();
      const todayKey = new Date(today.getFullYear(), today.getMonth(), today.getDate()).getTime();
      for (let i = 0; i < off; i++)g.innerHTML += '<div class="cd"></div>';
      let tot = 0, best = -Infinity, worst = Infinity, td = 0;
      for (let d = 1; d <= days; d++) {
        const k = `${y}-${String(m + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const hasDaily = Object.prototype.hasOwnProperty.call(PNL, k);
        const daily = Number(PNL[k] || 0);
        const counts = DAILY_COUNTS[k] || { wins: 0, losses: 0 };
        const hasTrades = Boolean(counts.wins || counts.losses);
        if (daily > 0) { tot += daily; if (daily > best) best = daily; td++; }
        else if (daily < 0) { tot += daily; if (daily < worst) worst = daily; td++; }
        else if (hasDaily && hasTrades) { td++; }
        const isTd = today.getFullYear() === y && today.getMonth() === m && today.getDate() === d;
        const dayKey = new Date(y, m, d).getTime();
        const isPast = dayKey < todayKey;
        let cls = 'cd', ps = '';
        if (daily > 0) { cls += ' profit'; ps = '+' + daily.toFixed(3); }
        else if (daily < 0) { cls += ' loss'; ps = daily.toFixed(3); }
        else if (hasDaily && hasTrades) { cls += ' zero'; ps = '0.000'; }
        else if (isPast) cls += ' zero';
        if (isTd) cls += ' today';
        const countParts = [];
        if (counts.wins) countParts.push(`<span>win ${counts.wins}x</span>`);
        if (counts.losses) countParts.push(`<span class="cdc-loss">loss ${counts.losses}x</span>`);
        const countText = countParts.join('<span> | </span>');
        g.innerHTML += `<div class="${cls}"><div class="cdn">${d}</div><div class="cdp">${ps}</div>${countText ? `<div class="cdc">${countText}</div>` : ''}</div>`;
      }
      document.getElementById('csT').textContent = (tot >= 0 ? '+' : '') + tot.toFixed(4) + ' SOL';
      document.getElementById('csT').className = 'mval ' + (tot >= 0 ? 'g' : 'r');
      document.getElementById('csB').textContent = best > -Infinity ? '+' + best.toFixed(4) + ' SOL' : '0.0000 SOL';
      document.getElementById('csW').textContent = worst < Infinity ? worst.toFixed(4) + ' SOL' : '0.0000 SOL';
      document.getElementById('csD').textContent = td;
    }

    function prevM() { CAL.month--; if (CAL.month < 0) { CAL.month = 11; CAL.year--; } renderCal(); }
    function nextM() { CAL.month++; if (CAL.month > 11) { CAL.month = 0; CAL.year++; } renderCal(); }
    function fmt(ms) { if (ms <= 0) return '00:00'; const m = Math.floor(ms / 60000), s = Math.floor((ms % 60000) / 1000); return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0'); }
    function fmtU(ms) { const h = Math.floor(ms / 3600000), m = Math.floor((ms % 3600000) / 60000), s = Math.floor((ms % 60000) / 1000); return String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0'); }

    setInterval(() => {
      mMs = Math.max(0, mMs - 1000); sMs = Math.max(0, sMs - 1000);
      if (mMs === 0) mMs = 10 * 60 * 1000;
      if (sMs === 0) { sMs = 30 * 60 * 1000; loadPools(); }
      document.getElementById('mTimer').textContent = fmt(mMs);
      document.getElementById('sTimer').textContent = fmt(sMs);
      if (startTime) document.getElementById('uptime').textContent = fmtU(Date.now() - startTime);
    }, 1000);

    async function loadAll() { await Promise.all([loadStatus(), loadPnl(), loadShadowIntelligence(), loadPools(), loadRanking(), loadFeatureImpact(), loadMomentumRider(), loadSmartWalletObserver(), loadMemeAlphaFinder()]); }
    loadAll();
    setInterval(loadAll, 30000);
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => { });
    }
  </script>
</body>

</html>

