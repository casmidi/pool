        setText('shadowV2ExitRoute', s2.exit_route_top || '--');
        setText('shadowV2Cases', String(s2.cases || 0));
        setText('shadowV2ClusterRisk', s2.cluster_risk_top || '--');
        setText('shadowV2Cause', s2.top_cause || 'none');
        const v2AdaptivePnl = Number(s2.adaptive_impact_sol || 0);
        const v2AdaptivePnlEl = document.getElementById('shadowV2AdaptivePnl');
        if (v2AdaptivePnlEl) {
          v2AdaptivePnlEl.textContent = (v2AdaptivePnl >= 0 ? '+' : '-') + Math.abs(v2AdaptivePnl).toFixed(4) + ' SOL';
          v2AdaptivePnlEl.style.color = v2AdaptivePnl > 0 ? 'var(--green)' : v2AdaptivePnl < 0 ? 'var(--red)' : 'var(--text)';
        }
        setText('shadowV2AdaptiveRoute', s2.adaptive_best_route || 'none');
        const v3Status = String(s3.status || 'LEARNING');
        const v3Pnl = Number(s3.rescue_pnl_sol || 0);
